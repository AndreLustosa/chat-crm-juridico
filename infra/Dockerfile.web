FROM node:20-alpine AS base

# Dependências necessárias para builds de web
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Instala todas as deps usando cache
COPY .npmrc* ./
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN npm install --legacy-peer-deps

# lightningcss usa optionalDependencies por plataforma. Em alguns runs
# do GitHub Actions Buildx, o npm pula a variante musl e o build do Next
# (com Turbopack) quebra: "Cannot find module ../lightningcss.linux-x64-musl.node".
# Força instalação explícita garante que o binário esteja sempre presente.
# Bug 2026-04-28: build do web caiu apos commit que nao tocou em CSS.
RUN npm install lightningcss-linux-x64-musl@~1 --no-save --legacy-peer-deps

# Agora copia fontes
COPY . .

# Faz o build do frontend Next.js indicando Next.js cache mode
WORKDIR /app/apps/web
ENV NEXT_TELEMETRY_DISABLED=1
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_GTM_ID
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_GTM_ID=$NEXT_PUBLIC_GTM_ID
RUN npm run build

# Imagem final hiper leve
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=base /app/apps/web/public ./apps/web/public

# Define permissões
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copia arquivos standalone do Next
COPY --from=base --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=base --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "apps/web/server.js"]
