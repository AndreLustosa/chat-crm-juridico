# ============================================
# LexCRM - Variaveis de Ambiente
# Copie para .env na raiz do projeto e preencha
# ============================================

# ------ Banco de Dados ------
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=lexcrm

# ------ JWT Auth ------
JWT_SECRET=TROQUE_POR_UMA_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=15m

# ------ Evolution API (WhatsApp) ------
# Opcional aqui - pode configurar pela UI em Ajustes > Integração WhatsApp
EVOLUTION_API_URL=https://seu-evolution.com
EVOLUTION_GLOBAL_APIKEY=sua_chave_global
EVOLUTION_INSTANCE_NAME=crm_instance

# ------ MinIO S3 (Storage de Mídias) ------
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chat-crm-media

# ------ Portas (opcionais - valores padrão mostrados) ------
API_PORT=43001
WEB_PORT=43000

# ------ URLs Públicas ------
# Local (docker-compose.prod.yml):
PUBLIC_API_URL=http://localhost:43001/api
NEXT_PUBLIC_API_URL=http://localhost:43001/api
NEXT_PUBLIC_WS_URL=http://localhost:43001

# Produção (Traefik):
# PUBLIC_API_URL=https://atendimento.andrelustosaadvogados.com.br/api
# NEXT_PUBLIC_API_URL=https://atendimento.andrelustosaadvogados.com.br/api
# NEXT_PUBLIC_WS_URL=wss://atendimento.andrelustosaadvogados.com.br
