model DjenIgnoredProcess {
  id              String   @id @default(uuid())
  numero_processo String   @unique
  tenant_id       String?
  reason          String?
  created_at      DateTime @default(now())
  tenant          Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
