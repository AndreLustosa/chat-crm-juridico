}

model FichaTrabalhista {
  id              String   @id @default(uuid())
  lead_id         String   @unique
  lead            Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  data            Json     @default("{}") // todos os ~80 campos do formulario
  nome_completo   String? // espelho para busca rapida
  nome_empregador String? // espelho para busca rapida
  finalizado      Boolean  @default(false)
  filled_by       String   @default("manual") // "manual" | "ai" | "lead"
  completion_pct  Int      @default(0) // 0-100
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([lead_id])
  @@index([finalizado])
}

model DjenPublication {
  id                    String     @id @default(uuid())
  comunicacao_id        Int        @unique
  data_disponibilizacao DateTime
  numero_processo       String
  classe_processual     String?
  assunto               String?
  tipo_comunicacao      String?
  conteudo              String
  nome_advogado         String?
  raw_json              Json
  legal_case_id         String?
  legal_case            LegalCase? @relation(fields: [legal_case_id], references: [id], onDelete: SetNull)
  viewed_at             DateTime?
  archived              Boolean    @default(false)
  auto_task_id          String?
  parte_autora          String?
  parte_rea             String?
  lawyer_analysis       Json?
  client_analysis       Json?
  analyzed_at           DateTime?
  client_notified_at    DateTime?
  created_at            DateTime   @default(now())

  @@index([data_disponibilizacao])
  @@index([numero_processo])
  @@index([legal_case_id])
  @@index([viewed_at])
