// ===============================================
// Follow-up IA — Sequências e Envios
// ===============================================

model FollowupSequence {
  id                 String               @id @default(cuid())
  tenant_id          String?
  name               String
  description        String?
  category           String               @default("LEADS") // LEADS | CLIENTS | COBRANCA | REENGAJAMENTO
  active             Boolean              @default(true)
  auto_enroll_stages String[]             @default([]) // ex: ["NOVO","QUALIFICANDO"]
  max_attempts       Int                  @default(6)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  tenant             Tenant?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  steps              FollowupStep[]
  enrollments        FollowupEnrollment[]
}

model FollowupStep {
  id            String            @id @default(cuid())
  sequence_id   String
  position      Int
  delay_hours   Int               @default(24)
  channel       String            @default("whatsapp") // whatsapp | email | ligacao
  tone          String            @default("amigavel") // amigavel | profissional | empatico | firme
  objective     String
  custom_prompt String?           @db.Text
  auto_send     Boolean           @default(true)
  created_at    DateTime          @default(now())
  sequence      FollowupSequence  @relation(fields: [sequence_id], references: [id], onDelete: Cascade)
  messages      FollowupMessage[]

  @@index([sequence_id, position])
}

model FollowupEnrollment {
  id            String            @id @default(cuid())
  lead_id       String
  sequence_id   String
  current_step  Int               @default(1)
  status        String            @default("ATIVO") // ATIVO | PAUSADO | CONCLUIDO | CANCELADO | CONVERTIDO
  enrolled_at   DateTime          @default(now())
  last_sent_at  DateTime?
  next_send_at  DateTime?
  paused_reason String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  lead          Lead              @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  sequence      FollowupSequence  @relation(fields: [sequence_id], references: [id], onDelete: Cascade)
  messages      FollowupMessage[]

  @@unique([lead_id, sequence_id])
  @@index([status, next_send_at])
}

model FollowupMessage {
  id             String             @id @default(cuid())
  enrollment_id  String
  step_id        String
  lead_id        String
  channel        String
  generated_text String             @db.Text
  sent_text      String?            @db.Text
  status         String             @default("PENDENTE_APROVACAO") // PENDENTE_APROVACAO | APROVADO | ENVIADO | REJEITADO | FALHOU
  approved_by    String?
  approved_at    DateTime?
  sent_at        DateTime?
  context_json   Json?
  risk_level     String             @default("baixo")
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  enrollment     FollowupEnrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  step           FollowupStep       @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@index([enrollment_id])
  @@index([status])
  @@index([lead_id])
}

// ===============================================
// Broadcast / Disparos em Massa
// ===============================================

model BroadcastJob {
  id            String    @id @default(cuid())
  tenant_id     String?
  name          String
  type          String    @default("AUDIENCIA")
  status        String    @default("PENDENTE")
  filter_json   Json?
  custom_prompt String?   @db.Text
  total_targets Int       @default(0)
  sent_count    Int       @default(0)
  failed_count  Int       @default(0)
  interval_ms   Int       @default(10000)
  started_at    DateTime?
  completed_at  DateTime?
  created_by_id String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  tenant     Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by User            @relation(fields: [created_by_id], references: [id])
  items      BroadcastItem[]

  @@index([tenant_id, status])
  @@index([created_at])
}

model BroadcastItem {
  id             String    @id @default(cuid())
  broadcast_id   String
  lead_id        String
  event_id       String?
  phone          String
  generated_text String?   @db.Text
  status         String    @default("PENDENTE")
  sent_at        DateTime?
  error          String?
  created_at     DateTime  @default(now())

  broadcast BroadcastJob @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)
  lead      Lead         @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([broadcast_id, status])
  @@index([lead_id])
}

// ===============================================
// Calendar / Agenda
// ===============================================

model CalendarEvent {
  id          String    @id @default(uuid())
  tenant_id   String?
  type        String // CONSULTA, TAREFA, AUDIENCIA, PRAZO, OUTRO
  title       String
  description String?
  start_at    DateTime
  end_at      DateTime?
  all_day     Boolean   @default(false)
  status      String    @default("AGENDADO") // AGENDADO, CONFIRMADO, CONCLUIDO, CANCELADO, ADIADO
  priority    String    @default("NORMAL") // BAIXA, NORMAL, ALTA, URGENTE
  color       String?
  location    String?

  lead_id             String?
  conversation_id     String?
  legal_case_id       String?
  assigned_user_id    String?
  created_by_id       String
  appointment_type_id String?

  // Audit de cumprimento — populado pelo EventsService quando status muda
  // para CONCLUIDO/CANCELADO/ADIADO. Nota fica disponivel no Workspace/Agenda
  // pra revisao posterior (ex: "audiencia ocorreu, acordo celebrado").
  completed_at    DateTime?
  completed_by_id String?
  completion_note String?

  // Recurrence
  recurrence_rule String? // DAILY, WEEKLY, BIWEEKLY, MONTHLY, CUSTOM
  recurrence_end  DateTime?
  recurrence_days Int[]           @default([]) // dias da semana para CUSTOM (0-6)
  parent_event_id String?
  parent_event    CalendarEvent?  @relation("RecurrenceChildren", fields: [parent_event_id], references: [id], onDelete: Cascade)
  child_events    CalendarEvent[] @relation("RecurrenceChildren")

  lead             Lead?            @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  conversation     Conversation?    @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  legal_case       LegalCase?       @relation(fields: [legal_case_id], references: [id], onDelete: SetNull)
  assigned_user    User?            @relation("EventAssigned", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  created_by       User             @relation("EventCreator", fields: [created_by_id], references: [id])
  completed_by     User?            @relation("EventCompleter", fields: [completed_by_id], references: [id], onDelete: SetNull)
  appointment_type AppointmentType? @relation(fields: [appointment_type_id], references: [id], onDelete: SetNull)

  reminders EventReminder[]
  comments  CalendarEventComment[]
  task      Task?
  deadline  CaseDeadline?
  tenant    Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  created_by_ai Boolean @default(false) // true quando o evento foi criado por tool da IA (book_appointment)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id, start_at])
  @@index([assigned_user_id, start_at])
  @@index([lead_id])
  @@index([legal_case_id])
  @@index([parent_event_id])
}

model EventReminder {
  id             String        @id @default(uuid())
  event_id       String
  event          CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  minutes_before Int // 15, 30, 60, 1440 (1 dia)
  channel        String        @default("PUSH") // PUSH, WHATSAPP, EMAIL
  sent_at        DateTime?

  @@index([event_id])
}

model UserSchedule {
  id          String  @id @default(uuid())
  user_id     String
  user        User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  day_of_week Int // 0=dom, 1=seg, ..., 6=sab
  start_time  String // "09:00"
  end_time    String // "18:00"
  lunch_start String? // "12:00" — null = sem pausa
  lunch_end   String? // "13:00"

  @@unique([user_id, day_of_week])
}

model AppointmentType {
  id        String  @id @default(uuid())
  tenant_id String?
  name      String // "Consulta Trabalhista 30min"
  duration  Int // minutos
  color     String?
  active    Boolean @default(true)

  events CalendarEvent[]
  tenant Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Holiday {
  id               String   @id @default(uuid())
  tenant_id        String?
  date             DateTime
  name             String
  recurring_yearly Boolean  @default(false)
  created_at       DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, date])
}

// ===============================================
// Lead Stage History (histórico de mudanças de estágio)
// ===============================================

model LeadStageHistory {
  id          String   @id @default(uuid())
  lead_id     String
  from_stage  String?
  to_stage    String
  actor_id    String?
  loss_reason String?
  created_at  DateTime @default(now())

  lead  Lead  @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  actor User? @relation("StageHistoryActor", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([lead_id, created_at])
}

// ===============================================
// Lead Notes (notas internas por contato)
// ===============================================

model LeadNote {
  id         String   @id @default(uuid())
  lead_id    String
  user_id    String
  text       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([lead_id, created_at])
  @@index([user_id])
}

model CalendarEventComment {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  text       String
  created_at DateTime @default(now())

  event CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id, created_at])
}

// ===============================================
// Case Documents (documentos organizados por caso)
// ===============================================

model CaseDocument {
  id                  String   @id @default(uuid())
  tenant_id           String?
  legal_case_id       String
  uploaded_by_id      String
  folder              String   @default("OUTROS") // CLIENTE, PROVAS, CONTRATOS, PETICOES, DECISOES, PROCURACOES, OUTROS
  name                String // Nome exibido
  original_name       String // Nome original do arquivo
  s3_key              String // Chave no MinIO/S3
  mime_type           String
  size                Int // bytes
  version             Int      @default(1)
  parent_id           String? // Para versionamento: aponta pro doc original
  description         String?
  // true = doc subido pelo cliente via /portal/enviar-documento. uploaded_by_id
  // aponta pro advogado responsavel (FK exige User), mas a UI deve mostrar
  // "Enviado pelo cliente" quando esta flag for true.
  uploaded_via_portal Boolean  @default(false)
  created_at          DateTime @default(now())

  legal_case  LegalCase      @relation(fields: [legal_case_id], references: [id], onDelete: Cascade)
  uploaded_by User           @relation("DocumentUploader", fields: [uploaded_by_id], references: [id])
  tenant      Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent      CaseDocument?  @relation("DocumentVersions", fields: [parent_id], references: [id], onDelete: SetNull)
  versions    CaseDocument[] @relation("DocumentVersions")

  @@index([legal_case_id, folder])
  @@index([parent_id])
  @@index([legal_case_id, uploaded_via_portal])
}

// ===============================================
// Case Transcriptions (transcrição de audiências)
// Video ASF/MP4/etc -> WhisperX -> texto + diarização
// ===============================================

model CaseTranscription {
  id              String    @id @default(uuid())
  tenant_id       String?
  // legal_case_id NULLABLE: transcrições avulsas (sem processo vinculado) são criadas
  // a partir do menu Ferramentas. Quando vinculadas, aparecem também na aba do workspace.
  legal_case_id   String?
  uploaded_by_id  String
  title           String
  // Job lifecycle: PENDING -> CONVERTING -> TRANSCRIBING -> DONE | ERROR
  status          String    @default("PENDING")
  progress        Int       @default(0) // 0-100
  error_message   String?
  // Provider usado (whisper-local, groq, ...) — permite histórico se trocar depois
  provider        String    @default("whisper-local")
  model           String? // ex: "large-v3"
  diarize         Boolean   @default(true)
  // Storage no MinIO/S3 (bucket chat-crm-media)
  source_s3_key   String // arquivo original enviado (ASF, MP4, MKV, etc.)
  source_mime     String
  source_size     Int
  // Convertido pra MP4 web-friendly (h264+aac) — usado no player do frontend
  video_s3_key    String?
  // Áudio extraído (WAV 16kHz) — só guardamos se precisar reprocessar
  audio_s3_key    String?
  // Resultado final
  language        String? // "pt", etc.
  duration_sec    Float? // duração do áudio
  text            String?   @db.Text // texto corrido (todos falantes juntos)
  segments_json   Json? // [{start,end,text,speaker}] - bloco por bloco
  words_json      Json? // [{start,end,word,speaker,score}] - word-level
  speakers_json   Json? // [{id:"SPEAKER_00", label:"Juiz", color:"#..."}] - labels editáveis
  // Job tracking
  external_job_id String? // id no crm-whisper (pra polling/retomada)
  started_at      DateTime?
  finished_at     DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  legal_case  LegalCase? @relation(fields: [legal_case_id], references: [id], onDelete: SetNull)
  uploaded_by User       @relation("TranscriptionUploader", fields: [uploaded_by_id], references: [id])
  tenant      Tenant?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([legal_case_id, created_at])
  @@index([status])
  @@index([tenant_id])
  @@index([uploaded_by_id, created_at])
}

// ===============================================
// Case Deadlines (prazos processuais)
// ===============================================

model CaseDeadline {
  id                String    @id @default(uuid())
  tenant_id         String?
  legal_case_id     String
  created_by_id     String
  type              String // CONTESTACAO, RECURSO, IMPUGNACAO, MANIFESTACAO, AUDIENCIA, PERICIA, OUTRO
  title             String
  description       String?
  due_at            DateTime
  alert_days        Int       @default(2) // Dias antes para alertar
  // Status normalizado (enum-like, espelha CalendarEvent):
  //   PENDENTE | CONCLUIDO | CANCELADO | ADIADO
  // Sincronizado com `completed` por triggers + service layer:
  //   completed = true  quando status IN ('CONCLUIDO', 'CANCELADO')
  //   completed = false quando status IN ('PENDENTE', 'ADIADO')
  // O campo `completed` fica como shortcut boolean pra queries legadas
  // (foi renomeado pra `is_closed` mentalmente, mas mantido pra compat).
  status            String    @default("PENDENTE")
  completed         Boolean   @default(false)
  completed_at      DateTime?
  completed_by_id   String?
  completion_note   String?
  calendar_event_id String?   @unique // Link para CalendarEvent gerado automaticamente
  created_at        DateTime  @default(now())

  legal_case     LegalCase      @relation(fields: [legal_case_id], references: [id], onDelete: Cascade)
  created_by     User           @relation("DeadlineCreator", fields: [created_by_id], references: [id])
  completed_by   User?          @relation("DeadlineCompleter", fields: [completed_by_id], references: [id], onDelete: SetNull)
  tenant         Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  calendar_event CalendarEvent? @relation(fields: [calendar_event_id], references: [id], onDelete: SetNull)

  @@index([legal_case_id, due_at])
  @@index([due_at, completed])
}

// ===============================================
// Case Petitions (petições jurídicas com editor)
// ===============================================

model CasePetition {
  id             String    @id @default(uuid())
  tenant_id      String?
  legal_case_id  String
  created_by_id  String
  title          String
  type           String // INICIAL, CONTESTACAO, REPLICA, EMBARGOS, RECURSO, MANIFESTACAO, OUTRO
  status         String    @default("RASCUNHO") // RASCUNHO, EM_REVISAO, APROVADA, PROTOCOLADA
  content_json   Json? // Tiptap JSON (editor state)
  content_html   String? // HTML renderizado (para export)
  template_id    String? // Se gerada a partir de template
  deadline_at    DateTime? // Prazo para conclusão da peça
  review_notes   String? // Observações do advogado na revisão
  reviewed_by_id String? // Quem revisou
  reviewed_at    DateTime? // Quando revisou
  google_doc_id  String? // Google Docs document ID
  google_doc_url String? // URL completa do Google Doc
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  legal_case  LegalCase         @relation(fields: [legal_case_id], references: [id], onDelete: Cascade)
  created_by  User              @relation("PetitionAuthor", fields: [created_by_id], references: [id])
  reviewed_by User?             @relation("PetitionReviewer", fields: [reviewed_by_id], references: [id])
  template    LegalTemplate?    @relation(fields: [template_id], references: [id], onDelete: SetNull)
  tenant      Tenant?           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  versions    PetitionVersion[]

  @@index([legal_case_id, status])
  @@index([created_by_id, status])
}

model PetitionVersion {
  id           String   @id @default(uuid())
  petition_id  String
  version      Int
  content_json Json
  content_html String?
  saved_by_id  String
  created_at   DateTime @default(now())

  petition CasePetition @relation(fields: [petition_id], references: [id], onDelete: Cascade)
  saved_by User         @relation("VersionSaver", fields: [saved_by_id], references: [id])

  @@index([petition_id, version])
}

// ===============================================
// Legal Templates (banco de peças / modelos)
// ===============================================

model LegalTemplate {
  id            String   @id @default(uuid())
  tenant_id     String?
  name          String
  type          String // INICIAL, CONTESTACAO, RECURSO, MANIFESTACAO, OUTRO
  legal_area    String? // TRABALHISTA, CIVIL, PREVIDENCIARIO, etc.
  content_json  Json // Tiptap JSON com placeholders {{nome_cliente}}, etc.
  variables     String[] @default([])
  description   String?
  is_global     Boolean  @default(false)
  usage_count   Int      @default(0)
  created_by_id String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  petitions  CasePetition[]
  created_by User?          @relation("TemplateCreator", fields: [created_by_id], references: [id])
  tenant     Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([legal_area, type])
}

model CaseHonorario {
  id                 String    @id @default(uuid())
  tenant_id          String?
  legal_case_id      String
  type               String // CONTRATUAL, SUCUMBENCIA, ENTRADA, ACORDO
  total_value        Decimal
  success_percentage Decimal? // Percentual de sucumbência (ex: 20.00 = 20%)
  calculated_value   Decimal? // Auto-calculado: sentence_value × percentage / 100
  sentence_value     Decimal? // Valor da condenação (SUCUMBENCIA)
  interest_rate      Decimal? // Taxa de juros mensal (padrão: 1% = juros legais)
  base_date          DateTime? // Data base para cálculo de juros
  status             String    @default("ATIVO") // ATIVO, FINALIZADO, CANCELADO
  installment_count  Int       @default(1)
  contract_date      DateTime?
  notes              String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  legal_case LegalCase          @relation(fields: [legal_case_id], references: [id], onDelete: Cascade)
  tenant     Tenant?            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  payments   HonorarioPayment[]

  @@index([legal_case_id])
  @@index([tenant_id])
}

model HonorarioPayment {
  id             String    @id @default(uuid())
  honorario_id   String
  amount         Decimal
  due_date       DateTime? // Opcional para alvará judicial (SUCUMBENCIA)
  paid_at        DateTime?
  payment_method String? // PIX, BOLETO, CARTAO, DINHEIRO, TRANSFERENCIA
  status         String    @default("PENDENTE") // PENDENTE, PAGO, ATRASADO
  notes          String?
  created_at     DateTime  @default(now())

  honorario             CaseHonorario         @relation(fields: [honorario_id], references: [id], onDelete: Cascade)
  financial_transaction FinancialTransaction?
  gateway_charge        PaymentGatewayCharge?

  @@index([honorario_id, due_date])
  @@index([status])
}

// ===============================================
// Honorários Negociados (fase de negociação/lead)
// ===============================================

model LeadHonorario {
  id                 String   @id @default(uuid())
  tenant_id          String?
  lead_id            String
  type               String // CONTRATUAL, ENTRADA, ACORDO
  total_value        Decimal
  success_percentage Decimal? // % sucumbência negociada antecipadamente
  installment_count  Int      @default(1)
  entry_value        Decimal? // Valor de entrada separado
  notes              String?
  status             String   @default("NEGOCIANDO") // NEGOCIANDO, ACEITO, RECUSADO, CONVERTIDO
  promoted_to_id     String? // ID do CaseHonorario após conversão
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  lead     Lead                   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant   Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  payments LeadHonorarioPayment[]

  @@index([lead_id])
  @@index([tenant_id])
}

model LeadHonorarioPayment {
  id                String    @id @default(uuid())
  lead_honorario_id String
  amount            Decimal
  due_date          DateTime?
  paid_at           DateTime?
  payment_method    String? // PIX, BOLETO, CARTAO, DINHEIRO, TRANSFERENCIA
  status            String    @default("PENDENTE") // PENDENTE, PAGO, ATRASADO
  notes             String?
  created_at        DateTime  @default(now())

  lead_honorario        LeadHonorario         @relation(fields: [lead_honorario_id], references: [id], onDelete: Cascade)
  financial_transaction FinancialTransaction?
  gateway_charge        PaymentGatewayCharge?

  @@index([lead_honorario_id, due_date])
  @@index([status])
}

// ===============================================
// Contract Signatures (integração Clicksign)
// ===============================================

model ContractSignature {
  id              String @id @default(uuid())
  lead_id         String
  conversation_id String

  // Referências Clicksign
  cs_document_key          String  @unique // key do documento no Clicksign
  cs_signer_key            String? // key do signatário
  cs_request_signature_key String? // key para construir URL de assinatura
  signing_url              String? // link enviado ao cliente via WhatsApp

  // PDF assinado (preenchido após webhook de conclusão)
  signed_s3_key String? // ex: contracts-signed/{id}.pdf

  // Status: PENDENTE | ASSINADO | CANCELADO | EXPIRADO
  status    String    @default("PENDENTE")
  signed_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lead         Lead         @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@index([conversation_id])
  @@index([cs_document_key])
  @@index([status])
}

// ===============================================
// AI Chat (Peticoes IA — conversas persistentes)
// ===============================================

model AiChat {
  id           String   @id @default(uuid())
  tenant_id    String?
  user_id      String
  title        String   @default("Nova Conversa")
  model        String   @default("claude-sonnet-4-6")
  container_id String? // Claude Console container (reuse across turns)
  updated_at   DateTime @updatedAt
  created_at   DateTime @default(now())

  user     User            @relation("AiChatOwner", fields: [user_id], references: [id], onDelete: Cascade)
  tenant   Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  messages AiChatMessage[]

  @@index([user_id, updated_at])
  @@index([tenant_id])
  @@index([updated_at])
}

model AiChatMessage {
  id         String   @id @default(uuid())
  chat_id    String
  role       String // 'user' | 'assistant'
  content    String   @db.Text
  files_json Json? // [{ fileId, filename }] — generated files
  created_at DateTime @default(now())

  chat AiChat @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@index([chat_id, created_at])
}

model AutomationRule {
  id           String   @id @default(cuid())
  tenant_id    String?
  name         String
  trigger      String // NEW_LEAD | STAGE_CHANGE | NO_RESPONSE_24H | NO_RESPONSE_48H | PAYMENT_OVERDUE
  action       String // ADD_TAG | SEND_INTERNAL_NOTE | CHANGE_STAGE
  action_value String
  enabled      Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([trigger, enabled])
}

// ===============================================
// Módulo Financeiro — Transações e Categorias
// ===============================================

model FinancialTransaction {
  id                String    @id @default(uuid())
  tenant_id         String?
  type              String // RECEITA, DESPESA
  category          String // HONORARIO, CONSULTA, CUSTAS_JUDICIAIS, PERICIA, DESLOCAMENTO, ESCRITORIO, OUTRO
  description       String
  amount            Decimal
  date              DateTime  @default(now()) // data da transação
  due_date          DateTime? // vencimento (para receitas/despesas futuras)
  paid_at           DateTime? // quando foi efetivamente pago/recebido
  payment_method    String? // PIX, BOLETO, CARTAO, DINHEIRO, TRANSFERENCIA
  status            String    @default("PENDENTE") // PENDENTE, PAGO, CANCELADO
  reference_id      String? // ID externo (gateway, NFS-e, etc.)
  notes             String?
  visible_to_lawyer Boolean   @default(true) // Se false, advogado não vê esta despesa

  // Recorrência
  is_recurring          Boolean   @default(false)
  recurrence_pattern    String? // MENSAL, TRIMESTRAL, SEMESTRAL, ANUAL
  recurrence_day        Int? // Dia do mês para vencimento (1-31)
  recurrence_end_date   DateTime? // Quando parar (null = indefinido)
  parent_transaction_id String? // Referência à transação mãe

  // Vínculos opcionais
  legal_case_id             String?
  lead_id                   String?
  lawyer_id                 String?
  honorario_payment_id      String? @unique // 1:1 com HonorarioPayment
  lead_honorario_payment_id String? @unique // 1:1 com LeadHonorarioPayment

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant                 Tenant?                          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  legal_case             LegalCase?                       @relation(fields: [legal_case_id], references: [id], onDelete: SetNull)
  lead                   Lead?                            @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  lawyer                 User?                            @relation("FinancialLawyer", fields: [lawyer_id], references: [id], onDelete: SetNull)
  honorario_payment      HonorarioPayment?                @relation(fields: [honorario_payment_id], references: [id], onDelete: SetNull)
  lead_honorario_payment LeadHonorarioPayment?            @relation(fields: [lead_honorario_payment_id], references: [id], onDelete: SetNull)
  gateway_charge         PaymentGatewayCharge?
  nota_fiscal            NotaFiscal?
  attachments            FinancialTransactionAttachment[]

  @@index([tenant_id, date])
  @@index([type, status])
  @@index([legal_case_id])
  @@index([lead_id])
  @@index([lawyer_id])
  @@index([category])
  @@index([due_date, status])
}

/// Histórico de relatórios gerados — auditoria + re-download.
/// PDFs são regenerados sob demanda a partir dos params salvos (mais simples
/// que armazenar blobs no S3 e expira sozinho). Registros antigos podem ser
/// purgados via cron (default: 90 dias).
model Report {
  id           String   @id @default(uuid())
  tenant_id    String?
  user_id      String? /// quem gerou (auditoria)
  /// Tipo do relatório: 'dashboard-snapshot', 'transactions-statement',
  /// 'charges-list', 'dre', 'cash-flow', etc.
  kind         String
  /// Parâmetros originais (period, lawyerId, filters, etc) — usados pra
  /// regenerar o PDF idêntico ao primeiro download.
  params       Json
  /// Display name pra UI (ex.: "Snapshot dashboard — Abril/2026")
  display_name String
  generated_at DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   User?   @relation("ReportGeneratedBy", fields: [user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, generated_at])
  @@index([user_id, generated_at])
  @@index([kind])
}

/// Anexos vinculados a uma FinancialTransaction (receitas/despesas).
/// Pre-requisito do "Pacote de comprovantes" pra contadora.
/// Suporta arquivos PDF e imagens (JPG, PNG). Limite de 10MB por arquivo
/// validado no controller.
model FinancialTransactionAttachment {
  id             String   @id @default(uuid())
  tenant_id      String?
  transaction_id String
  filename       String /// Nome original do arquivo (ex: "nota-fiscal-001.pdf")
  mime_type      String /// "application/pdf", "image/jpeg", etc
  size_bytes     Int
  /// S3 key (ou path local) onde o arquivo esta armazenado.
  /// Padrao: "financial-attachments/<tenant_id>/<transaction_id>/<id>-<filename>"
  storage_key    String
  uploaded_by_id String?
  created_at     DateTime @default(now())

  tenant      Tenant?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  transaction FinancialTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  uploaded_by User?                @relation("FinancialAttachmentUploader", fields: [uploaded_by_id], references: [id], onDelete: SetNull)

  @@index([transaction_id])
  @@index([tenant_id, created_at])
}

model FinancialCategory {
  id         String   @id @default(uuid())
  tenant_id  String?
  type       String // RECEITA, DESPESA
  name       String
  icon       String?
  is_default Boolean  @default(false)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, name, type])
  @@index([tenant_id, type])
}

/// Meta mensal — 3 dimensoes:
///   - escopo: escritorio (lawyer_id=null) ou advogado especifico
///   - tipo: REALIZED (caixa, paid_at no mes) ou CONTRACTED (vendido no mes)
///   - mes/ano + tenant_id (multi-tenant)
///
/// Soft delete via deleted_at preserva historico (nunca apaga fisicamente).
/// Unique parcial (tenant_id, lawyer_id, year, month, kind) onde deleted_at
/// is null — gerenciado via SQL manual em manual-sql/ pq Prisma nao expressa
/// indices parciais com COALESCE.
model MonthlyGoal {
  id            String    @id @default(uuid())
  tenant_id     String?
  /// NULL = escopo escritorio. UUID = advogado especifico.
  lawyer_id     String?
  year          Int
  month         Int // 1-12 (validado no app)
  /// 'REALIZED' | 'CONTRACTED'
  kind          String    @default("REALIZED")
  value         Decimal   @db.Decimal(14, 2)
  created_by_id String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  tenant     Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lawyer     User?   @relation("MonthlyGoalLawyer", fields: [lawyer_id], references: [id], onDelete: Cascade)
  created_by User?   @relation("MonthlyGoalCreator", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, year, month])
  @@index([lawyer_id, year])
  @@index([year, month])
}

// ===============================================
// Payment Gateway — Asaas / EfiBank
// ===============================================

model PaymentGatewayCustomer {
  id             String   @id @default(uuid())
  tenant_id      String?
  lead_id        String
  gateway        String   @default("ASAAS") // ASAAS, EFIBANK
  external_id    String // ID do cliente no gateway
  cpf_cnpj       String?
  sync_status    String   @default("SYNCED") // SYNCED, ERROR
  last_synced_at DateTime @default(now())
  created_at     DateTime @default(now())

  lead   Lead    @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, lead_id, gateway])
  @@unique([gateway, external_id])
  @@index([lead_id])
}

model PaymentGatewayCharge {
  id                   String   @id @default(uuid())
  tenant_id            String?
  honorario_payment_id String?  @unique
  transaction_id       String?  @unique
  legal_case_id        String?
  gateway              String   @default("ASAAS")
  external_id          String   @unique // ID da cobrança no gateway
  customer_external_id String // ID do cliente no gateway
  billing_type         String // PIX, BOLETO, CREDIT_CARD
  amount               Decimal
  due_date             DateTime
  status               String   @default("PENDING") // PENDING, RECEIVED, CONFIRMED, OVERDUE, REFUNDED, DELETED, CANCELLED
  description          String?

  // PIX
  pix_qr_code         String?
  pix_copy_paste      String?
  pix_expiration_date DateTime?

  // Boleto
  boleto_url     String?
  boleto_barcode String?

  // Resultado
  invoice_url     String?
  paid_at         DateTime?
  payment_date    DateTime?
  net_value       Decimal?
  webhook_payload Json?

  idempotency_key String?  @unique
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Tracking de cobranca enviada ao cliente — evita spam e permite
  // escalonamento (1=cordial, 2=firme, 3=urgente, 4+=alerta interno).
  // last_reminder_kind eh string descritiva tipo 'initial' | 'pre-due-3d' |
  // 'pre-due-1d' | 'pre-due-0d' | 'overdue-1d' | 'overdue-3d' | 'overdue-7d'.
  last_reminder_sent_at DateTime?
  reminder_count        Int       @default(0)
  last_reminder_kind    String?

  lead_honorario_payment_id String?               @unique
  honorario_payment         HonorarioPayment?     @relation(fields: [honorario_payment_id], references: [id], onDelete: SetNull)
  lead_honorario_payment    LeadHonorarioPayment? @relation(fields: [lead_honorario_payment_id], references: [id], onDelete: SetNull)
  transaction               FinancialTransaction? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  legal_case                LegalCase?            @relation(fields: [legal_case_id], references: [id], onDelete: SetNull)
  tenant                    Tenant?               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status])
  @@index([customer_external_id])
  @@index([due_date, status])
  @@index([legal_case_id])
}

// ===============================================
// Nota Fiscal Eletrônica (NFS-e)
// ===============================================

model NotaFiscal {
  id                   String  @id @default(uuid())
  tenant_id            String?
  transaction_id       String? @unique // 1:1 com FinancialTransaction
  honorario_payment_id String?
  lead_id              String?

  // NFS-e data
  numero             String?
  codigo_verificacao String?
  status             String   @default("PENDENTE") // PENDENTE, EMITIDA, CANCELADA, ERRO
  servico_codigo     String? // Código CNAE ou LC 116
  servico_descricao  String   @default("Serviços advocatícios")
  valor              Decimal
  aliquota_iss       Decimal? @default(5.00)
  valor_iss          Decimal?

  // Tomador (cliente)
  tomador_cpf_cnpj String?
  tomador_nome     String?
  tomador_email    String?

  // Integração com agregador
  provider      String? // ENOTAS, NFEIO, FOCUSNFE
  external_id   String? @unique
  xml_url       String?
  pdf_url       String?
  error_message String?

  emitida_em   DateTime?
  cancelada_em DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  transaction FinancialTransaction? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  lead        Lead?                 @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  tenant      Tenant?               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status])
  @@index([lead_id])
  @@index([emitida_em])
}

// ===============================================
// Controle Tributário — Carnê-Leão / DARF
// ===============================================

model TaxRecord {
  id        String  @id @default(uuid())
  tenant_id String?
  lawyer_id String
  year      Int
  month     Int // 1-12

  total_revenue    Decimal @default(0)
  total_deductions Decimal @default(0)
  taxable_income   Decimal @default(0)
  tax_due          Decimal @default(0)

  darf_code     String    @default("0190") // Carnê-Leão
  darf_due_date DateTime?
  darf_paid     Boolean   @default(false)
  darf_paid_at  DateTime?
  notes         String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lawyer User    @relation("TaxRecordLawyer", fields: [lawyer_id], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, lawyer_id, year, month])
  @@index([lawyer_id, year])
}

model ConversationNote {
  id              String   @id @default(uuid())
  conversation_id String
  user_id         String
  text            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationNoteAuthor", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
}

/// Preferências de notificação por usuário — controle granular por tipo × canal.
/// Substitui localStorage para sincronizar entre dispositivos.
model NotificationSetting {
  id          String    @id @default(uuid())
  user_id     String    @unique
  sound_id    String    @default("ding")
  muted_until DateTime?
  preferences Json      @default("{}")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

/// Mute de conversa — permite silenciar notificações de uma conversa específica.
model ConversationMute {
  id              String    @id @default(uuid())
  user_id         String
  conversation_id String
  muted_until     DateTime? /// null = mudo indefinidamente
  created_at      DateTime  @default(now())

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@unique([user_id, conversation_id])
  @@index([user_id])
}

/// Histórico persistente de notificações — feed de atividade com read/unread.
model Notification {
  id                String    @id @default(uuid())
  user_id           String
  tenant_id         String?
  notification_type String /// incoming_message, transfer_request, task_overdue, etc.
  title             String
  body              String?
  data              Json? /// { conversationId, taskId, caseId, etc. }
  read_at           DateTime?
  /// Quando o WhatsApp fallback foi enviado pra essa notif. Usado pra dedup
  /// agressivo (1 WA por conversa por hora, independente de read_at).
  whatsapp_sent_at  DateTime?
  created_at        DateTime  @default(now())

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at])
  @@index([user_id, created_at])
  @@index([user_id, whatsapp_sent_at])
}

/// Subscriptions de Web Push — permite notificações com a aba do navegador fechada.
model PushSubscription {
  id          String   @id @default(uuid())
  user_id     String
  endpoint    String   @unique
  keys_p256dh String
  keys_auth   String
  user_agent  String?
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ===============================================
// Memory System — Lead + Organization memories
// ===============================================

/// Memória persistente sobre leads e sobre o escritório. Cada Memory é uma
/// unidade atômica de conhecimento (1 frase / fato). A coluna `embedding`
/// (pgvector) é adicionada via migration SQL — Prisma não suporta vector
/// nativamente. Use $queryRaw/$executeRaw para operações envolvendo embedding.
model Memory {
  id        String @id @default(uuid())
  tenant_id String

  /// "lead" | "organization"
  scope    String
  /// ID do lead (scope=lead) ou ID do tenant (scope=organization)
  scope_id String

  /// "semantic" | "episodic" | "procedural"
  type        String  @default("semantic")
  /// Subcategoria (scope=organization): office_info | team | fees | procedures | court_info | legal_knowledge | contacts | rules
  subcategory String?

  content String @db.Text

  /// Embedding OpenAI text-embedding-3-small (1536 dim). Tipo pgvector —
  /// Prisma nao suporta nativamente, entao usamos Unsupported. Isso impede
  /// que `prisma db push` REMOVA a coluna por nao reconhece-la no schema.
  /// Leitura/escrita sempre via $queryRawUnsafe/$executeRawUnsafe.
  /// IMPORTANTE: a extensao pgvector deve estar habilitada no Postgres antes
  /// do primeiro `db push` em ambientes novos — ver manual-sql/2026-04-18-memory-system.sql.
  embedding Unsupported("vector(1536)")?

  // Proveniência
  /// "batch" | "manual" | "system" | "retroactive"
  source_type String
  /// ID da conversa que originou (quando source_type=batch)
  source_id   String?
  confidence  Float   @default(1.0)

  // Ciclo de vida
  /// "active" | "superseded" | "archived"
  status        String    @default("active")
  /// Razão da substituição ou ID da memória substituta
  superseded_by String?
  access_count  Int       @default(0)
  last_accessed DateTime?
  expires_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, scope, scope_id])
  @@index([status])
  @@index([tenant_id, subcategory])
}

/// Perfil consolidado do lead — summary em texto corrido + facts JSON.
/// Regenerado pelo cron noturno após extração de memórias. É o "cartão" que
/// a IA lê antes de responder para já conhecer o cliente sem repetir perguntas.
model LeadProfile {
  id        String @id @default(uuid())
  tenant_id String
  lead_id   String @unique
  lead      Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant    Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  /// Texto corrido (~300 palavras) — injetado no system prompt
  summary String @db.Text
  /// JSON estruturado: name, cpf, cases[], preferences, pending, sentiment, risk_flags…
  facts   Json   @default("{}")

  generated_at  DateTime @default(now())
  message_count Int      @default(0)
  version       Int      @default(1)

  @@index([tenant_id])
}

/// Perfil consolidado do ESCRITORIO — resumo em prosa (4 secoes) que substitui
/// a injecao crua das memorias organizacionais no prompt. Mesmo padrao do
/// LeadProfile mas para tenant. 1 registro por tenant.
///
/// Regenerado:
///   - Diariamente as 02h (OrgProfileConsolidationProcessor)
///   - Sob demanda apos create/update/delete de memoria organizacional (debounce)
///   - Via botao manual na tela /atendimento/settings/knowledge
///
/// Na injecao, substitui `{{office_memories}}` no prompt — reduz ruido,
/// resolve conflitos e descarta memorias de baixa confianca.
model OrganizationProfile {
  id        String @id @default(uuid())
  tenant_id String @unique
  tenant    Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  /// Texto estruturado em 4 secoes (About, Team, Procedures, Rules) — ~500 palavras
  summary String @db.Text
  /// JSON estruturado: office_info, team[], fees, procedures[], rules[], etc.
  facts   Json   @default("{}")

  /// Quantas memorias ativas foram usadas como fonte na ultima geracao
  source_memory_count Int @default(0)

  /// Timestamp da ultima edicao manual do admin. Quando nao-null, o cron
  /// automatico das 02h PULA este tenant (nao sobrescreve a edicao). Limpo
  /// quando o admin clica "Regenerar" explicitamente via UI/API.
  manually_edited_at DateTime?

  /// Marca ate quando as memorias ja foram incorporadas ao summary
  /// (modo incremental). Na proxima regen incremental, so processa memorias
  /// criadas/deletadas APOS este timestamp — economiza LLM tokens e preserva
  /// o texto existente. Resetado pelo botao "Refazer do zero" (from-scratch).
  last_incorporated_at DateTime?

  generated_at DateTime @default(now())
  version      Int      @default(1)
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULO: Gestao de Trafego Google Ads
// ─────────────────────────────────────────────────────────────────────────────
// Single-account scope: cada tenant conecta UMA conta Ads (anunciante)
// via OAuth. O modulo le metricas via Google Ads API e armazena snapshots
// diarios para dashboard/alertas/relatorios. NAO faz mutate de campanhas.
//
// Fluxo:
//   1. Admin conecta conta -> TrafficAccount com refresh_token (cripto AES-256)
//   2. Worker (cron 06h Maceio) le metricas dos ultimos 7 dias e upserta
//      em TrafficMetricDaily (idempotente via unique constraint)
//   3. TrafficSyncLog grava cada execucao (success/error/duration) — auditoria
//   4. Regras de TrafficSettings disparam TrafficAlert quando KPIs saem da meta
// ─────────────────────────────────────────────────────────────────────────────

/// Conta Google Ads conectada via OAuth 2.0.
///
/// Single-account por tenant nesta fase (unique tenant_id). Para suportar
/// multiplas contas no futuro, basta remover o @unique do tenant_id e
/// adicionar selector na UI.
///
/// refresh_token: criptografado com AES-256-GCM (TrafficCryptoService).
/// developer_token: NAO armazenado aqui — vem da env GOOGLE_ADS_DEVELOPER_TOKEN
/// (compartilhado entre todos os tenants). login_customer_id eh o ID da MCC
/// que autoriza a chamada (sem tracos, ex: "2736107831").
model TrafficAccount {
  id                String    @id @default(uuid())
  tenant_id         String    @unique
  /// Customer ID da conta-alvo (anunciante), sem tracos. Ex: "4464129633"
  customer_id       String
  /// Customer ID da MCC que detem o developer token. Ex: "2736107831"
  login_customer_id String?
  /// Email do Google que autorizou o OAuth (display only).
  authorized_email  String?
  /// Display name do anunciante (cacheado da API). Ex: "André Lustosa Advogados"
  account_name      String?
  /// Moeda da conta (ISO 4217). Ex: "BRL", "USD"
  currency_code     String?
  /// Timezone IANA da conta. Ex: "America/Maceio"
  time_zone         String?
  /// Refresh token OAuth criptografado (AES-256-GCM). Formato: iv:authTag:ciphertext
  /// (base64). Decriptado apenas em memoria pelo worker durante sync.
  refresh_token_enc String    @db.Text
  /// Status da conexao: "ACTIVE" | "REVOKED" | "ERROR" | "PENDING"
  status            String    @default("ACTIVE")
  /// Quando o ultimo sync rodou com sucesso. null = nunca sincronizou.
  last_sync_at      DateTime?
  /// Mensagem do ultimo erro (se status=ERROR). null = sem erro pendente.
  last_error        String?   @db.Text
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  tenant             Tenant                      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  campaigns          TrafficCampaign[]
  metrics_daily      TrafficMetricDaily[]
  sync_logs          TrafficSyncLog[]
  alerts             TrafficAlert[]
  mutate_logs        TrafficMutateLog[]
  ad_groups          TrafficAdGroup[]
  keywords           TrafficKeyword[]
  ads                TrafficAd[]
  budgets            TrafficCampaignBudget[]
  bulk_jobs          TrafficBulkJob[]
  conversion_actions TrafficConversionAction[]
  oci_uploads        TrafficOCIUpload[]
  lead_form_subs     TrafficLeadFormSubmission[]
  ia_decisions       TrafficIADecision[]
  user_lists         TrafficUserList[]
  user_list_members  TrafficUserListMember[]
  recommendations    TrafficRecommendation[]
  asset_groups       TrafficAssetGroup[]
  asset_group_assets TrafficAssetGroupAsset[]
  reach_forecasts    TrafficReachForecast[]

  @@index([status])
  @@index([last_sync_at])
}

/// Cache de metadata de campanhas Google Ads (atualizado a cada sync).
/// NAO eh fonte da verdade — apenas snapshot local pra exibir lista sem bater
/// na API. Os campos mutaveis (status, budget, name) sao reescritos em cada sync.
///
/// google_campaign_id eh o ID numerico vindo da API (campaign.id). Combinado
/// com account_id forma a chave natural unica.
model TrafficCampaign {
  id                   String    @id @default(uuid())
  tenant_id            String
  account_id           String
  /// ID numerico do Google (campaign.id). Ex: "21458273619"
  google_campaign_id   String
  /// Nome da campanha vindo da API
  name                 String
  /// Status: "ENABLED" | "PAUSED" | "REMOVED"
  status               String
  /// Tipo: "SEARCH" | "PERFORMANCE_MAX" | "DISPLAY" | "VIDEO" | "DEMAND_GEN" etc.
  channel_type         String?
  /// Orcamento diario em micros (1 BRL = 1.000.000 micros). null se shared budget.
  daily_budget_micros  BigInt?
  /// resource_name do campaign_budget vinculado (ex: "customers/X/campaignBudgets/Y").
  /// Cache vinda do sync (campaign.campaign_budget). Necessario pra mutates de budget
  /// sem precisar fazer round-trip no Google Ads.
  budget_resource_name String?
  /// Estrategia de lance: "MAXIMIZE_CONVERSIONS" | "TARGET_CPA" | etc.
  bidding_strategy     String?
  /// Datas da campanha (vindas da API)
  start_date           DateTime?
  end_date             DateTime?

  // ─── Anotacoes internas (do escritorio, nao da API) ─────────────────────
  /// Marcada como favorita no painel
  is_favorite          Boolean  @default(false)
  /// Pausada internamente (nao reflete no Google Ads — apenas oculta do dashboard)
  is_archived_internal Boolean  @default(false)
  /// Tags arbitrarias do operador (ex: ["maceio", "trabalhista"])
  tags                 String[] @default([])
  /// Notas livres
  notes                String?  @db.Text

  /// Objetivo declarado pra distinguir KPIs e regras de avaliacao.
  /// 'PERFORMANCE' (otimiza por conversao — default) | 'BRANDING' (otimiza
  /// por alcance/awareness) | 'HYBRID' (remarketing). Deduzido do
  /// channel_type por default (Search/PMax/LSA = PERFORMANCE,
  /// Demand Gen/Display prospect = BRANDING, Display remarketing = HYBRID).
  /// Admin pode override em Configuracoes.
  objective String @default("PERFORMANCE")

  /// Categoria interna do escritorio (servico). Usado pra tags + metas
  /// diferenciadas por servico. Ex: "trabalhista", "civil", "empresarial",
  /// "familia", "consumidor", "inventario", "penal".
  service_category String?

  /// Ultima vez que esta campanha foi vista no sync (detecta REMOVED)
  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account       TrafficAccount       @relation(fields: [account_id], references: [id], onDelete: Cascade)
  metrics_daily TrafficMetricDaily[]
  ad_groups     TrafficAdGroup[]
  asset_groups  TrafficAssetGroup[]

  @@unique([account_id, google_campaign_id])
  @@index([tenant_id, status])
  @@index([is_favorite])
  @@index([last_seen_at])
  @@index([service_category])
  @@index([objective])
}

/// Metricas agregadas por dia x campanha. Granularidade minima do dashboard.
/// Idempotente via unique (campaign_id, date) — re-sync sobrescreve.
///
/// Valores monetarios em micros (1 BRL = 1.000.000) — padrao Google Ads API,
/// evita arredondamento de Decimal e simplifica BigInt.
model TrafficMetricDaily {
  id          String   @id @default(uuid())
  tenant_id   String
  account_id  String
  campaign_id String
  date        DateTime @db.Date

  // ─── Metricas brutas da API ─────────────────────────────────────────────
  impressions       Int     @default(0)
  clicks            Int     @default(0)
  cost_micros       BigInt  @default(0) // gasto em micros
  conversions       Decimal @default(0) // pode ser fracionario (atribuicao)
  conversions_value Decimal @default(0) // valor das conversoes (se configurado)

  // ─── Derivadas (calculadas no upsert pra acelerar query do dashboard) ───
  /// CTR = clicks / impressions (0..1)
  ctr                  Decimal @default(0)
  /// CPC medio em micros = cost_micros / clicks (null se clicks=0)
  avg_cpc_micros       BigInt?
  /// CPL = cost_micros / conversions, em micros (null se conversions=0)
  cost_per_conv_micros BigInt?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account  TrafficAccount  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  campaign TrafficCampaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, date])
  @@index([tenant_id, date])
  @@index([account_id, date])
  @@index([date])
}

/// Log estruturado de cada execucao do sync (cron ou manual).
/// Usado pra debug, auditoria e exibicao do "ultimo sync" no dashboard.
/// Retencao: 90 dias (purge via cron).
model TrafficSyncLog {
  id             String    @id @default(uuid())
  tenant_id      String
  account_id     String
  /// "CRON" | "MANUAL" | "OAUTH_CALLBACK"
  trigger        String
  /// "SUCCESS" | "ERROR" | "PARTIAL"
  status         String
  /// Range sincronizado (inclusive)
  date_from      DateTime? @db.Date
  date_to        DateTime? @db.Date
  /// Quantas linhas de TrafficMetricDaily foram upsertadas
  rows_upserted  Int       @default(0)
  /// Quantas campanhas foram detectadas
  campaigns_seen Int       @default(0)
  /// Stack/mensagem de erro (se status != SUCCESS)
  error_message  String?   @db.Text
  /// Duracao em ms
  duration_ms    Int?
  started_at     DateTime  @default(now())
  finished_at    DateTime?

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, started_at(sort: Desc)])
  @@index([account_id, status, started_at(sort: Desc)])
  @@index([started_at])
}

/// Alertas operacionais detectados pelo motor de regras (TrafficAlertEvaluator).
/// Disparados pelo cron pos-sync. Notificam via canais configurados em
/// TrafficSettings (email/whatsapp/inapp).
///
/// dedupe_key: hash determinÃ­stico (kind + campaign_id + date_bucket) pra
/// evitar disparar o mesmo alerta multiplas vezes no mesmo periodo.
model TrafficAlert {
  id              String    @id @default(uuid())
  tenant_id       String
  account_id      String
  /// ID da campanha relacionada (null se alerta de conta)
  campaign_id     String?
  /// "HIGH_CPL" | "LOW_CTR" | "BUDGET_EXHAUSTED" | "ZERO_CONVERSIONS"
  /// "CAMPAIGN_PAUSED" | "OVERSPEND" | "NO_DATA" | "API_ERROR"
  kind            String
  /// "INFO" | "WARNING" | "CRITICAL"
  severity        String    @default("WARNING")
  /// Mensagem human-readable (ex: "CPL da campanha X subiu 45% em 7 dias")
  message         String    @db.Text
  /// Contexto estruturado (valores observados, threshold, etc)
  context         Json      @default("{}")
  /// Hash pra dedupe (evita re-disparar mesmo alerta)
  dedupe_key      String
  /// Status do alerta: "OPEN" | "ACKNOWLEDGED" | "RESOLVED" | "MUTED"
  status          String    @default("OPEN")
  /// Quem reconheceu (null = nao acknowledged)
  acknowledged_by String?
  acknowledged_at DateTime?
  /// Quando foi notificado por email/WA (null = ainda nao)
  notified_at     DateTime?
  created_at      DateTime  @default(now())

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([dedupe_key])
  @@index([tenant_id, status, created_at(sort: Desc)])
  @@index([account_id, kind])
  @@index([severity, status])
}

/// Configuracoes do modulo de trafego por tenant (singleton).
/// Metas, thresholds de alerta, canais de notificacao.
model TrafficSettings {
  id        String @id @default(uuid())
  tenant_id String @unique

  // ─── Metas (em micros — padrao API) ─────────────────────────────────────
  /// CPL alvo em micros (BRL). Default: 50 BRL = 50_000_000 micros
  target_cpl_micros          BigInt  @default(50000000)
  /// CTR alvo (0..1). Default: 0.03 = 3%
  target_ctr                 Decimal @default(0.03)
  /// ROAS alvo (multiplicador). Default: 3.0
  target_roas                Decimal @default(3.0)
  /// Orcamento diario total alvo em micros. null = sem alvo agregado.
  target_daily_budget_micros BigInt?

  // ─── Thresholds de alerta ───────────────────────────────────────────────
  /// Disparar HIGH_CPL se CPL > target_cpl * (1 + cpl_alert_threshold).
  /// Default: 0.30 = +30%
  cpl_alert_threshold Decimal @default(0.30)
  /// Disparar LOW_CTR se CTR < target_ctr * (1 - ctr_alert_threshold).
  /// Default: 0.30 = -30%
  ctr_alert_threshold Decimal @default(0.30)
  /// Janela de dias para avaliar tendencia de CPL/CTR. Default: 7
  alert_window_days   Int     @default(7)

  // ─── Canais de notificacao ──────────────────────────────────────────────
  /// Enviar alertas por email (usa NotificationSetting do user?)
  notify_email          Boolean @default(true)
  /// Enviar alertas por WhatsApp (reusa servico whatsapp existente)
  notify_whatsapp       Boolean @default(false)
  /// Telefone destinatario do WhatsApp (E.164). null = usa do admin.
  notify_whatsapp_phone String?
  /// Notificacao in-app (sino do CRM)
  notify_inapp          Boolean @default(true)

  // ─── Sync ───────────────────────────────────────────────────────────────
  /// Hora local (Maceio) que o cron diario roda. Default: 6 (06:00)
  sync_hour_local Int     @default(6)
  /// Habilitar sync automatico
  sync_enabled    Boolean @default(true)

  // ─── Credenciais Google Ads API ─────────────────────────────────────────
  // Configuradas via UI (admin) — substitui env vars. Quando null, sistema
  // faz fallback pra env (compat com setup atual).
  //
  // Secrets criptografados com TRAFEGO_ENCRYPTION_KEY (mesma chave dos
  // refresh_tokens). Nunca retornados em plaintext na API — get retorna
  // mascarado (****1234), patch sobrescreve apenas se valor novo for enviado.
  /// Developer Token do Google Ads (criptografado). Vem da MCC do escritorio.
  google_ads_developer_token_enc String?
  /// Customer ID da MCC (sem tracos), ex: "2736107831". Nao secreto.
  google_ads_login_customer_id   String?
  /// Customer ID da conta-alvo (anunciante), sem tracos. Ex: "4464129633".
  /// Quando definido, OAuth callback popula TrafficAccount.customer_id com este valor
  /// e updateCredentials sincroniza com TrafficAccount existente (single-account scope).
  google_ads_customer_id         String?
  /// OAuth Client ID do Google Cloud (publico, vai no frontend OAuth flow).
  oauth_client_id                String?
  /// OAuth Client Secret (criptografado). Comeca com "GOCSPX-".
  oauth_client_secret_enc        String?
  /// URL pra onde Google redireciona apos consent. Ex: <api>/trafego/oauth/callback
  oauth_redirect_uri             String?
  /// Base URL do frontend (pra redirect pos-callback do nosso backend pro UI).
  frontend_base_url              String?

  // ─── Sprint D: Lead Form Asset webhook ──────────────────────────────────
  /// Secret compartilhado configurado no Lead Form Asset do Google Ads.
  /// Google envia em cada submit (param `google_key` na URL ou header).
  /// Webhook so processa requests com key matching — anti-spam.
  lead_form_webhook_secret   String?
  /// Auto-cria Lead no CRM ao receber submission. Default: true.
  /// Quando false, submissions ficam em PENDING pra revisao manual.
  lead_form_auto_create_lead Boolean @default(true)
  /// Stage default do Lead criado a partir de Lead Form. Ex: "INTERESSADO".
  lead_form_default_stage    String  @default("INTERESSADO")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

/// Auditoria de toda escrita feita na Google Ads API (mutate).
/// Toda chamada que altera estado da conta passa pelo GoogleAdsMutateService
/// e grava aqui ANTES de executar. Permite replay/diagnostico, garante
/// idempotencia via request_id e suporta reverso de operacoes recentes.
///
/// resource_type: "campaign" | "ad_group" | "ad_group_ad" | "ad_group_criterion"
///                "campaign_budget" | "campaign_criterion" | "conversion_action"
///                "customer_match_user_list" | "asset" | "remarketing_action"
/// operation:     "create" | "update" | "remove"
///
/// payload guarda o array de operations enviado pra API (resource_name,
/// update_mask, valores). result guarda os resource_names retornados
/// (success) ou partial_failure_error (parcial).
model TrafficMutateLog {
  id            String   @id @default(uuid())
  tenant_id     String
  account_id    String
  /// ID determinístico passado no header pra idempotencia. Mesma key = mesma resposta.
  request_id    String   @unique
  /// Tipo do recurso modificado (ex: "campaign")
  resource_type String
  /// Operação ("create" | "update" | "remove")
  operation     String
  /// Quem disparou — "ai_agent:hourly" | "ai_agent:daily" | "user:<userId>" | "system:sync"
  initiator     String
  /// Score de confiança da IA (null se nao foi IA). 0..1
  confidence    Decimal?
  /// Operations[] enviado pra API (sanitizado — sem secrets)
  payload       Json     @default("{}")
  /// Resposta da API (resource_names ou partial_failure_error)
  result        Json     @default("{}")
  /// "PENDING" | "SUCCESS" | "PARTIAL" | "FAILED" | "REVERTED"
  status        String   @default("PENDING")
  /// Mensagem de erro humana (preenche se FAILED ou PARTIAL)
  error_message String?  @db.Text
  /// Validate-only? (dry-run que nao persistiu na API)
  validate_only Boolean  @default(false)
  /// Tempo de execucao em ms (latencia da API)
  duration_ms   Int?
  /// Se foi revertido por outra operação, aponta o id da operação reverso
  reverted_by   String?
  /// IDs CRM relacionados (lead_id, campaign_id local, etc) pra correlação
  context       Json     @default("{}")
  created_at    DateTime @default(now())

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([account_id, resource_type, created_at(sort: Desc)])
  @@index([initiator, created_at(sort: Desc)])
  @@index([status])
}

/// Cache de ad_groups (grupos de anuncios) atualizado a cada sync.
/// Hierarquia: Campaign > AdGroup > Ad/Keyword.
///
/// google_ad_group_id: ID numerico vindo de ad_group.id na API.
/// Combinado com campaign_id forma a chave unica.
model TrafficAdGroup {
  id                   String   @id @default(uuid())
  tenant_id            String
  account_id           String
  campaign_id          String
  /// ID numerico do Google (ad_group.id)
  google_ad_group_id   String
  /// Nome do grupo
  name                 String
  /// Status: "ENABLED" | "PAUSED" | "REMOVED"
  status               String
  /// Tipo: "SEARCH_STANDARD" | "DISPLAY_STANDARD" | "VIDEO_BUMPER" etc.
  type                 String?
  /// Bid CPC manual em micros (se bidding strategy permitir)
  cpc_bid_micros       BigInt?
  /// Bid CPM manual em micros
  cpm_bid_micros       BigInt?
  /// Target CPA em micros (se TARGET_CPA na campanha ou override no grupo)
  target_cpa_micros    BigInt?
  /// Target ROAS multiplicador (se MAX_CONVERSION_VALUE)
  target_roas          Decimal?
  /// Pausada internamente (oculto do dashboard, sem mexer no Google)
  is_archived_internal Boolean  @default(false)
  /// Notas livres do operador
  notes                String?  @db.Text

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account  TrafficAccount   @relation(fields: [account_id], references: [id], onDelete: Cascade)
  campaign TrafficCampaign  @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  keywords TrafficKeyword[]
  ads      TrafficAd[]

  @@unique([campaign_id, google_ad_group_id])
  @@index([tenant_id, status])
  @@index([account_id, last_seen_at])
}

/// Cache de palavras-chave de Search/Shopping (ad_group_criterion type=KEYWORD).
/// Tambem armazena negativas (negative=true). Lista crescente — IA aplica
/// negatives obvios (>= 0.95 confidence) e operador revisa as restantes.
///
/// match_type: "EXACT" | "PHRASE" | "BROAD"
/// quality_info: snapshot do quality_score, expected_ctr, ad_relevance,
///               landing_page_experience (vem na API mas eh "static" — calculado
///               no momento do sync, nao mais).
model TrafficKeyword {
  id                  String   @id @default(uuid())
  tenant_id           String
  account_id          String
  ad_group_id         String
  /// criterion_id do Google (ad_group_criterion.criterion_id)
  google_criterion_id String
  /// Texto da keyword (ex: "advogado trabalhista maceio")
  text                String
  /// Tipo de match: "EXACT" | "PHRASE" | "BROAD"
  match_type          String
  /// true se eh negativa (criterion.negative=true)
  negative            Boolean  @default(false)
  /// Status: "ENABLED" | "PAUSED" | "REMOVED"
  status              String
  /// CPC bid override no criterio (se nao usar do ad_group)
  cpc_bid_micros      BigInt?
  /// Quality Score (1-10), null se sem dados ainda
  quality_score       Int?
  /// JSON com expected_ctr, ad_relevance, landing_page_experience
  quality_info        Json?
  /// Adicionada pela IA (true) ou pelo operador (false)
  added_by_ai         Boolean  @default(false)
  /// Score de confiança da IA na adicao (null se manual)
  ai_confidence       Decimal?

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account  TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  ad_group TrafficAdGroup @relation(fields: [ad_group_id], references: [id], onDelete: Cascade)

  @@unique([ad_group_id, google_criterion_id])
  @@index([tenant_id, negative])
  @@index([account_id, status])
  @@index([text])
}

/// Cache de anuncios (ad_group_ad). Inclui RSAs (Responsive Search Ads),
/// Performance Max assets, Demand Gen ads etc.
///
/// approval_status: "APPROVED" | "DISAPPROVED" | "UNDER_REVIEW" | "ELIGIBLE"
/// Critico para detectar reprovacao (mirror automatico em outros grupos).
///
/// final_urls/headlines/descriptions: arrays JSON do conteudo do anuncio.
/// Validados pelo OABValidatorService antes de criar/atualizar.
model TrafficAd {
  id              String   @id @default(uuid())
  tenant_id       String
  account_id      String
  ad_group_id     String
  /// ad_group_ad.ad.id do Google
  google_ad_id    String
  /// Tipo: "RESPONSIVE_SEARCH_AD" | "EXPANDED_TEXT_AD" | "RESPONSIVE_DISPLAY_AD"
  ///       "PERFORMANCE_MAX_AD" | "DEMAND_GEN_VIDEO_AD" etc.
  ad_type         String
  /// Status do ad_group_ad: "ENABLED" | "PAUSED" | "REMOVED"
  status          String
  /// Approval status do AdsApp policy summary
  approval_status String?
  /// Topics de policy violations (se DISAPPROVED). Array string
  policy_topics   String[] @default([])
  /// URLs finais (array)
  final_urls      Json     @default("[]")
  /// Headlines (RSA: array de {text, pinned_field?}). JSON pra flex.
  headlines       Json     @default("[]")
  /// Descriptions (RSA: array de {text, pinned_field?})
  descriptions    Json     @default("[]")
  /// Path1, Path2 (display URL paths)
  path1           String?
  path2           String?
  /// Snapshot integral do ad object (pra reverter ou debug)
  ad_payload      Json?
  /// Adicionado pela IA (true) ou operador (false)
  added_by_ai     Boolean  @default(false)
  ai_confidence   Decimal?

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account  TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  ad_group TrafficAdGroup @relation(fields: [ad_group_id], references: [id], onDelete: Cascade)

  @@unique([ad_group_id, google_ad_id])
  @@index([tenant_id, approval_status])
  @@index([account_id, status])
  @@index([ad_type])
}

/// Cache de campaign_budgets (orçamento dedicado ou compartilhado).
/// Uma budget pode ser usada por 1+ campanhas (shared). amount_micros eh
/// o orçamento DIARIO em micros.
model TrafficCampaignBudget {
  id               String  @id @default(uuid())
  tenant_id        String
  account_id       String
  /// campaign_budget.id do Google
  google_budget_id String
  /// Nome do budget
  name             String?
  /// Orcamento diario em micros
  amount_micros    BigInt
  /// Tipo: "STANDARD" (estandartizado) | "FIXED_DAILY"
  delivery_method  String?
  /// Compartilhado entre 1+ campanhas? (campaign_budget.explicitly_shared)
  is_shared        Boolean @default(false)
  /// Mesmo valor de reference_count da API (quantas campanhas usam)
  reference_count  Int     @default(0)
  /// Status: "ENABLED" | "REMOVED"
  status           String  @default("ENABLED")

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([account_id, google_budget_id])
  @@index([tenant_id, is_shared])
}

/// Tracking de batch jobs (BatchJobService da API). Usa-se quando precisa
/// fazer 100+ mutates simultaneos (ex: aplicar 200 negative keywords).
/// Job roda async no Google — polling periodico atualiza status local.
///
/// resource_name vem da API ("customers/X/batchJobs/Y"). status:
/// "PENDING" | "RUNNING" | "DONE" | "REMOVED"
model TrafficBulkJob {
  id            String    @id @default(uuid())
  tenant_id     String
  account_id    String
  /// "customers/X/batchJobs/Y" — usado pra polling getOperations()
  resource_name String    @unique
  /// "ADD_NEGATIVES" | "PAUSE_KEYWORDS" | "BULK_BUDGET_UPDATE" | etc.
  job_kind      String
  /// "PENDING" | "RUNNING" | "DONE" | "FAILED" | "REMOVED"
  status        String    @default("PENDING")
  /// Quantas operations foram enfileiradas
  total_ops     Int       @default(0)
  /// Quantas tiveram sucesso (preenchido apos polling)
  succeeded_ops Int       @default(0)
  /// Quantas falharam
  failed_ops    Int       @default(0)
  /// Iniciador: "ai_agent:weekly" | "user:<id>" etc.
  initiator     String
  /// Snapshot das operations enviadas (pra replay/debug)
  operations    Json      @default("[]")
  /// Resultado consolidado (resource_names + erros)
  result        Json      @default("{}")
  /// Mensagem de erro top-level (quando status=FAILED)
  error_message String?   @db.Text
  /// Quando o job comecou no Google (api timestamp)
  started_at    DateTime?
  /// Quando o job terminou (DONE ou FAILED)
  finished_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status])
  @@index([account_id, job_kind, created_at(sort: Desc)])
}

/// Cache de ConversionActions configurados na conta + mapeamento pra eventos do CRM.
/// Conversao = lead, agendamento, contrato assinado, pagamento.
///
/// crm_event_kind: nome do evento interno do CRM ("lead.created" |
/// "lead.qualified" | "client.signed" | "payment.received") que dispara
/// o upload OCI dessa conversao. null = nao mapeado (operador precisa configurar).
///
/// Categories Google: "DEFAULT" | "PAGE_VIEW" | "PURCHASE" | "SIGNUP"
/// "LEAD" | "DOWNLOAD" | "ADD_TO_CART" | "BEGIN_CHECKOUT" | "SUBSCRIBE_PAID" etc.
model TrafficConversionAction {
  id                     String  @id @default(uuid())
  tenant_id              String
  account_id             String
  /// conversion_action.id do Google
  google_conversion_id   String
  /// Nome (ex: "Lead Qualificado", "Contrato Assinado")
  name                   String
  /// Category Google
  category               String
  /// Status: "ENABLED" | "REMOVED" | "HIDDEN"
  status                 String
  /// Type: "AD_CALL" | "CLICK_TO_CALL" | "GOOGLE_PLAY_DOWNLOAD" |
  ///       "UPLOAD_CLICKS" | "UPLOAD_CALLS" | "WEBPAGE" | "WEBSITE_CALL" etc.
  type                   String?
  /// Counting: "ONE_PER_CLICK" | "MANY_PER_CLICK"
  counting_type          String?
  /// Janela de atribuicao em dias (default 30)
  click_through_lookback Int?
  /// Inclui essa conversao no Smart Bidding? (default true)
  include_in_conversions Boolean @default(true)
  /// Mapeamento pra evento CRM. null = nao mapeado.
  /// Valores: "lead.created" | "lead.qualified" | "client.signed" |
  ///          "payment.received" | "appointment.scheduled" | custom
  crm_event_kind         String?
  /// Valor monetario default (em micros) atribuido a esse evento.
  /// Usado quando upload OCI nao tem valor especifico.
  default_value_micros   BigInt?

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account     TrafficAccount     @relation(fields: [account_id], references: [id], onDelete: Cascade)
  oci_uploads TrafficOCIUpload[]

  @@unique([account_id, google_conversion_id])
  @@index([tenant_id, status])
  @@index([crm_event_kind])
}

/// Log de uploads OCI (Offline Conversion Imports) — sobe no Google Ads as
/// conversoes que aconteceram OFFLINE depois do click (lead virou cliente,
/// cliente pagou, etc). Via UploadClickConversion ou UploadCallConversion.
///
/// dedupe_chave (gclid + conversion_action + conversion_at): Google rejeita
/// duplicatas do mesmo gclid x conversao x timestamp. Logamos pra evitar
/// retry idempotentes derrubarem cota.
///
/// status: "PENDING" | "UPLOADED" | "FAILED" | "DUPLICATE_REJECTED"
model TrafficOCIUpload {
  id                   String    @id @default(uuid())
  tenant_id            String
  account_id           String
  /// FK pra conversion action mapeada
  conversion_action_id String
  /// Lead CRM origem (null se upload manual)
  lead_id              String?
  /// gclid do click original (essencial — sem isso Google nao atribui)
  gclid                String?
  /// gbraid (iOS app campaigns)
  gbraid               String?
  /// wbraid (web cookieless)
  wbraid               String?
  /// SHA-256 do email normalizado (pra Enhanced Conversions for Leads)
  email_sha256         String?
  /// SHA-256 do telefone E.164 normalizado
  phone_sha256         String?
  /// Order ID custom (pra dedupe no Google: 1 conversao por order_id)
  order_id             String?
  /// Timestamp da conversao (quando o evento offline aconteceu)
  conversion_at        DateTime
  /// Valor da conversao em micros (null = usa default_value do conversion_action)
  value_micros         BigInt?
  /// Currency ISO 4217 (null = usa do account)
  currency_code        String?
  /// "PENDING" | "UPLOADED" | "FAILED" | "DUPLICATE_REJECTED"
  status               String    @default("PENDING")
  /// Mensagem de erro (se FAILED)
  error_message        String?   @db.Text
  /// Resposta da API (resource_names ou partial_failure)
  api_response         Json?
  /// Quando subiu pro Google (preenchido apos sucesso)
  uploaded_at          DateTime?
  /// Trigger event: "lead.created" | "client.signed" | "payment.received" | "manual"
  trigger_event        String
  /// Foi upload manual via UI? (true) ou automatico via listener? (false)
  manual               Boolean   @default(false)
  created_at           DateTime  @default(now())

  tenant            Tenant                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account           TrafficAccount          @relation(fields: [account_id], references: [id], onDelete: Cascade)
  conversion_action TrafficConversionAction @relation(fields: [conversion_action_id], references: [id], onDelete: Cascade)
  lead              Lead?                   @relation(fields: [lead_id], references: [id], onDelete: SetNull)

  /// Dedupe ativo: nao subir mesmo gclid+action+timestamp duas vezes
  @@unique([conversion_action_id, gclid, conversion_at], name: "uq_oci_dedupe")
  @@index([tenant_id, status, created_at(sort: Desc)])
  @@index([account_id, status])
  @@index([lead_id])
  @@index([gclid])
  @@index([email_sha256])
  @@index([order_id])
  @@index([conversion_at])
}

/// Submissoes do Lead Form Asset (formulario nativo do Google Ads).
/// Recebidas via webhook configurado no asset (webhook_url + webhook_key).
/// Convertidas em Lead do CRM e em UploadOCI quando lead vira cliente.
///
/// raw_payload guarda o JSON cru recebido pra debug. Campos extraidos
/// (full_name, email, phone, gclid) ja sao populados em colunas dedicadas
/// pra index e dedupe.
model TrafficLeadFormSubmission {
  id              String    @id @default(uuid())
  tenant_id       String
  account_id      String
  /// asset.id do Lead Form
  google_asset_id String?
  /// campaign_id local (se conseguir mapear)
  campaign_id     String?
  /// gclid do click que gerou o lead
  gclid           String?
  gbraid          String?
  wbraid          String?
  /// Campos basicos extraidos do form
  full_name       String?
  email           String?
  phone           String?
  /// Outros campos (qualifiers, comentarios) — flex
  custom_fields   Json      @default("{}")
  /// IP do submitter (LGPD: anonimizar apos 30 dias se nao virou lead)
  ip_address      String?
  /// User agent do submitter
  user_agent      String?
  /// Lead criado a partir desse form (null se ainda nao processado ou rejeitado)
  lead_id         String?
  /// "PENDING" | "PROCESSED" | "DUPLICATE" | "REJECTED" | "ERROR"
  status          String    @default("PENDING")
  /// Mensagem de erro (se ERROR)
  error_message   String?   @db.Text
  /// Payload bruto recebido (audit trail)
  raw_payload     Json      @default("{}")
  /// Timestamp do submit no Google (vem no payload)
  submitted_at    DateTime
  created_at      DateTime  @default(now())
  processed_at    DateTime?

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  lead    Lead?          @relation(fields: [lead_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, status, created_at(sort: Desc)])
  @@index([account_id, status])
  @@index([gclid])
  @@index([email])
  @@index([phone])
  @@index([lead_id])
}

// ─────────────────────────────────────────────────────────────────────────
// AI AGENT (Sprint C)
//
// Toda decisao tomada pela IA (executada, sugerida ou bloqueada) eh persistida
// pra auditoria. Policy define limites de auto-execucao por tenant. Memory
// guarda estado entre loops (ex: "ja avaliei essa campanha como morta ha 3
// dias e admin nao agiu — escalar prioridade").
// ─────────────────────────────────────────────────────────────────────────

/// Decisao tomada pela IA. Auditoria perpetua — nunca apagar (regra OAB).
/// Cada loop (HOURLY/DAILY/WEEKLY/MONTHLY/TRIGGERED) gera 0+ decisoes.
model TrafficIADecision {
  id         String @id @default(uuid())
  tenant_id  String
  account_id String

  /// Loop que gerou: 'HOURLY' | 'DAILY' | 'WEEKLY' | 'MONTHLY' | 'TRIGGERED'
  loop_kind String

  /// Tipo: 'ADD_NEGATIVE_KEYWORD' | 'PAUSE_AD_REPROVED' |
  /// 'BUDGET_INCREASE_SUGGESTION' | 'CAMPAIGN_DEAD_ALERT' |
  /// 'HIGH_CPL_WARNING' | 'LOW_CTR_WARNING' | 'ZERO_CONVERSIONS' |
  /// 'OVERSPEND' | etc.
  decision_kind String

  /// Recurso afetado (se aplicavel)
  resource_type String? // 'CAMPAIGN' | 'AD_GROUP' | 'KEYWORD' | etc
  resource_id   String? // FK semântica (TrafficCampaign.id, etc)
  resource_name String? // nome humano pra exibir na UI

  /// Inputs usados (snapshot dos dados que alimentaram a decisao)
  inputs Json

  /// Score de confidence (0..1)
  confidence Decimal @db.Decimal(4, 3)

  /// Razoes estruturadas (JSON array de strings em pt-BR)
  reasons Json

  /// Que faria? Ja fez?
  /// 'EXECUTE' (auto-aplicada) | 'SUGGEST' (sugerida ao humano) |
  /// 'BLOCK' (bloqueada por OAB) | 'NOTIFY_ONLY' (so alerta, sem mutate) |
  /// 'FAILED' (tentou executar e falhou)
  action        String
  executed      Boolean @default(false)
  /// FK pra TrafficMutateLog se executou
  mutate_log_id String?

  /// Feedback do humano: 'APPROVED' | 'REVERTED' | 'IGNORED' | null
  human_feedback String?
  feedback_at    DateTime?
  feedback_note  String?   @db.Text

  /// Texto resumido pra UI (1 frase pt-BR). Gerado pela LLM ou template.
  summary String? @db.Text

  created_at DateTime @default(now())

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, decision_kind, created_at(sort: Desc)])
  @@index([account_id, action, created_at(sort: Desc)])
  @@index([action, human_feedback])
  @@index([executed, created_at(sort: Desc)])
}

/// Memoria persistente da IA entre loops. Chave/valor com TTL opcional.
/// Exemplos de chave:
///   - 'last_daily_run_at'           — debouncing
///   - 'campaign_X_dead_check_count' — escalation tracking
///   - 'overspend_X_notified_at'     — anti-spam de alertas
model TrafficIAMemory {
  id        String @id @default(uuid())
  tenant_id String

  key   String
  value Json

  expires_at DateTime?
  updated_at DateTime  @updatedAt
  created_at DateTime  @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, key])
  @@index([expires_at])
}

/// Policy do AI agent — toggle Conselheiro vs Autonomo + limites granulares.
/// 1 row por tenant. agent_enabled=false desliga TODOS os loops; toggles
/// individuais (auto_apply_*) controlam quais acoes podem ser executadas
/// automaticamente em modo Autonomo. Modo Conselheiro = todos auto_apply_*
/// false (so sugere, nunca executa).
model TrafficIAPolicy {
  id        String @id @default(uuid())
  tenant_id String @unique

  /// Habilita IA agente em geral (cron loops rodam ou nao)
  agent_enabled Boolean @default(false)

  /// Modo geral: 'ADVISOR' (so sugere) | 'AUTONOMOUS' (executa quando confidence >= threshold).
  /// Pra quem quer toggle simples sem mexer em cada auto_apply_*. Quando
  /// 'ADVISOR', todos auto_apply_* sao ignorados (forcado false).
  mode String @default("ADVISOR")

  /// Maximo de acoes auto-executadas por dia (rate limit hard)
  max_auto_actions_per_day Int @default(10)

  /// Confidence minimo pra auto-executar (default 0.95 = bem conservador)
  min_confidence_for_auto Decimal @default(0.95) @db.Decimal(4, 3)

  /// Toggle granular por tipo de acao (modo AUTONOMOUS)
  auto_apply_negative_keywords         Boolean @default(false)
  auto_apply_pause_disapproved         Boolean @default(true)
  auto_apply_rsa_asset_recommendations Boolean @default(false)
  auto_apply_budget_changes            Boolean @default(false)
  auto_apply_bidding_strategy_changes  Boolean @default(false)

  /// Limites de mutate (anti-explosao)
  /// Maximo de mudanca em budget por aplicacao (0.20 = 20%)
  max_budget_change_percent  Decimal @default(0.20) @db.Decimal(4, 3)
  /// Quantas mudancas de budget por semana (anti-pingue-pongue)
  max_budget_change_per_week Int     @default(1)
  /// Maximo de negative keywords auto-aplicadas por semana
  max_negatives_per_week     Int     @default(20)

  /// Janela de rollback (horas) — se admin reverter dentro dessa janela,
  /// IA marca como REVERTED e ajusta confidence pra mesma decisao no futuro
  rollback_window_hours Int @default(24)

  /// Canais de notificacao
  notify_admin_email    Boolean @default(true)
  notify_admin_whatsapp Boolean @default(true)
  notify_admin_inapp    Boolean @default(true)

  /// Se admin nao responde sugestao em N horas, IA escala (notif. mais forte)
  escalation_hours Int @default(48)

  /// Schedule dos loops (cron strings em pt-BR friendly format)
  /// Default: daily 06:30, weekly Mon 09:00, monthly day 1 09:00
  daily_cron   String @default("30 6 * * *")
  weekly_cron  String @default("0 9 * * 1")
  monthly_cron String @default("0 9 1 * *")

  /// Hourly loop (ex: alertas de overspend mid-day) — opcional
  hourly_enabled Boolean @default(false)

  /// Shadow mode: IA "decide" mas nao executa (so loga + notifica). Util
  /// nos primeiros 14 dias pra calibrar antes de soltar Autonomo.
  shadow_mode Boolean @default(true)

  // ─── Sprint G: configuracao de LLM ──────────────────────────────────────
  /// Provider do LLM usado para tarefas que exigem inteligencia natural
  /// (classify search terms, gerar summary). 'openai' | 'anthropic'
  llm_provider       String @default("anthropic")
  /// Modelo padrao pra summary writing. Default claude-haiku-4-5 (rapido + barato).
  llm_summary_model  String @default("claude-haiku-4-5")
  /// Modelo padrao pra classificacao de search terms (loop weekly — usar barato).
  llm_classify_model String @default("claude-haiku-4-5")

  // ─── Sprint G: cooldowns adaptativos ─────────────────────────────────────
  /// Janela em dias durante a qual uma sugestao IGNORED pelo admin nao deve
  /// reaparecer pra mesma combinacao (decision_kind, resource_id).
  ignored_cooldown_days    Int @default(30)
  /// Janela em dias pra penalizar confidence apos REVERTED.
  reverted_penalty_days    Int @default(90)
  /// Numero maximo de re-sugestoes (escalation strikes) antes de auto-IGNORE.
  max_resuggestion_strikes Int @default(3)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMER MATCH (Sprint D)
//
// User lists pra remarketing/exclusao. Cada lista mantem um espelho local
// dos members (hash SHA-256 de email/phone) pra detectar diff entre o que
// esta no Google Ads e o que deveria estar (com base nos clientes/leads do
// CRM). Worker faz upload incremental via OfflineUserDataJobService.
//
// Tipos comuns:
//   - "CLIENTES_ATIVOS"      pra excluir das prospect campaigns
//   - "LEADS_QUALIFICADOS"   pra remarketing de quem virou lead mas nao
//                            assinou ainda
//   - "LOOKALIKE_BASE"       pra usar como seed do Similar audiences
// ─────────────────────────────────────────────────────────────────────────

/// User list (audience) sincronizada com o Google Ads.
model TrafficUserList {
  id         String @id @default(uuid())
  tenant_id  String
  account_id String

  /// user_list.id retornado pelo Google Ads (numerico). Null antes do 1o
  /// upload bem-sucedido.
  google_user_list_id  String?
  /// user_list resource_name 'customers/X/userLists/Y'
  google_resource_name String?

  /// Nome da lista no Google Ads (padrao: "{tenant} — {kind}")
  name        String
  /// Descricao livre exibida no Google Ads
  description String?

  /// Tipo logico interno do CRM:
  ///   "CLIENTES_ATIVOS" — clientes assinados (uso: exclude prospect campaigns)
  ///   "LEADS_QUALIFICADOS" — leads em estagio avancado (uso: remarketing)
  ///   "LOOKALIKE_BASE" — base pra similar audiences
  ///   "CUSTOM" — admin definiu manualmente
  kind String

  /// CRM_BASED_USER_LIST com upload type FIRST_PARTY (LGPD-friendly).
  /// Membership lifespan em dias (max 540 do Google).
  membership_lifespan_days Int @default(540)

  /// Status interno: "DRAFT" | "SYNCING" | "READY" | "ERROR"
  status        String  @default("DRAFT")
  /// Mensagem de erro do ultimo upload (se ERROR)
  error_message String? @db.Text

  /// Contagem reportada pelo Google na ultima sync
  google_size_reported Int?
  /// Contagem local (TrafficUserListMember)
  local_size           Int  @default(0)

  last_synced_at DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  members TrafficUserListMember[]

  @@unique([account_id, kind])
  @@index([tenant_id, status])
}

/// Member individual de uma user list. email_sha256 e phone_sha256 sao os
/// hashes que efetivamente sobem pro Google (PII NUNCA sai em claro).
///
/// op_pending controla o que precisa ser feito no proximo upload:
///   "ADD"     — ainda nao subiu
///   "REMOVE"  — precisa remover do Google Ads (cliente saiu da audiencia)
///   null      — sincronizado, nada pendente
model TrafficUserListMember {
  id           String @id @default(uuid())
  tenant_id    String
  account_id   String
  user_list_id String

  /// FK opcional pra Lead/Client local (audit trail)
  lead_id String?

  /// SHA-256 lowercase do email (Google espera assim)
  email_sha256      String?
  /// SHA-256 lowercase do telefone E.164 (com +55, sem espacos)
  phone_sha256      String?
  /// SHA-256 do first_name lowercase trimmed
  first_name_sha256 String?
  /// SHA-256 do last_name lowercase trimmed
  last_name_sha256  String?

  /// Op pendente: 'ADD' | 'REMOVE' | null (sincronizado)
  op_pending    String?
  /// Quando foi adicionado/removido com sucesso no Google
  synced_at     DateTime?
  /// Erro do ultimo attempt
  error_message String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account   TrafficAccount  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  user_list TrafficUserList @relation(fields: [user_list_id], references: [id], onDelete: Cascade)

  @@unique([user_list_id, email_sha256, phone_sha256])
  @@index([account_id, op_pending])
  @@index([lead_id])
}

// ─────────────────────────────────────────────────────────────────────────
// RECOMMENDATIONS API (Sprint E)
//
// Cache local das recommendations vindas da Google Ads API. Cada
// recomendacao passa por OAB validator antes de ser elegivel pra apply
// automatico (ex: TEXT_AD com "garantia" eh BLOCKED). Admin pode aplicar
// manualmente a partir da UI mesmo se filtro OAB pegar (override).
//
// status:
//   "PENDING"      — vista no Google, ainda nao avaliada
//   "OAB_BLOCKED"  — OAB validator reprovou (admin pode override)
//   "READY"        — passou OAB, pronta pra aplicar (manual ou auto)
//   "APPLIED"      — aplicada com sucesso (referencia mutate_log_id)
//   "DISMISSED"    — admin descartou (registra dismiss no Google tambem)
//   "EXPIRED"      — sumiu da listagem do Google (ja nao aplicavel)
//   "ERROR"        — apply tentou mas falhou
// ─────────────────────────────────────────────────────────────────────────

model TrafficRecommendation {
  id         String @id @default(uuid())
  tenant_id  String
  account_id String

  /// resource_name 'customers/X/recommendations/Y'
  google_resource_name String
  /// Tipo: 'KEYWORD' | 'KEYWORD_NEGATIVE' | 'CAMPAIGN_BUDGET' |
  /// 'TEXT_AD' | 'RESPONSIVE_SEARCH_AD' | 'RESPONSIVE_SEARCH_AD_ASSET' |
  /// 'CALLOUT_ASSET' | 'SITELINK_ASSET' | 'TARGET_CPA_OPT_IN' |
  /// 'TARGET_ROAS_OPT_IN' | 'MAXIMIZE_CONVERSIONS_OPT_IN' |
  /// 'KEYWORD_MATCH_TYPE' | 'USE_BROAD_MATCH_KEYWORD' | 'OPTIMIZE_AD_ROTATION'
  /// | etc — ver api-recommendations.md (80+ tipos)
  recommendation_type  String

  /// FK semantica pra recurso afetado (TrafficCampaign.id, TrafficAdGroup.id)
  campaign_id String?
  ad_group_id String?

  /// Snapshot completo do payload da API (todos os campos do tipo)
  payload Json

  /// Impact projetado: clicks/conversions/cost ANTES e DEPOIS de aplicar
  impact_base      Json?
  impact_potential Json?

  /// Status interno (vide enum acima)
  status String @default("PENDING")

  /// Resultado da validacao OAB (se aplicavel ao tipo)
  oab_violations Json?
  /// Razoes filtragem (mensagens pt-BR pra exibir no UI)
  oab_summary    String? @db.Text

  /// Quando applied/dismissed
  resolved_at   DateTime?
  /// FK pra TrafficMutateLog se applied
  mutate_log_id String?
  /// Erro do ultimo apply (se ERROR)
  error_message String?   @db.Text

  /// Quem aplicou/descartou (User.id ou 'AI_AGENT')
  resolved_by String?

  /// Quando viu no Google pela primeira vez / ultima vez
  first_seen_at DateTime @default(now())
  last_seen_at  DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([account_id, google_resource_name])
  @@index([tenant_id, status, recommendation_type])
  @@index([account_id, status])
  @@index([campaign_id])
}

// ─────────────────────────────────────────────────────────────────────────
// PMAX / DEMAND GEN — Asset Groups (Sprint F)
//
// Estrutura: Campaign (PERFORMANCE_MAX|DEMAND_GEN) → AssetGroup → Asset.
// asset_group_asset eh a tabela de ligacao N:N (AssetGroup × Asset com
// field_type, ex: HEADLINE/IMAGE/VIDEO/CTA/LOGO).
//
// Cache local serve pra:
//   - Listar asset groups na UI sem hit na API a cada visita
//   - Identificar assets com performance_label=LOW (Google avalia)
//   - Mostrar ad_strength (POOR | AVERAGE | GOOD | EXCELLENT)
// ─────────────────────────────────────────────────────────────────────────

/// Cache de asset_group da Google Ads API (PMax + Demand Gen).
model TrafficAssetGroup {
  id          String @id @default(uuid())
  tenant_id   String
  account_id  String
  campaign_id String

  /// asset_group.id do Google
  google_asset_group_id String
  /// asset_group resource_name 'customers/X/assetGroups/Y'
  google_resource_name  String

  /// Nome do asset group
  name           String
  /// "ENABLED" | "PAUSED" | "REMOVED"
  status         String
  /// Ad strength agregado: "POOR" | "AVERAGE" | "GOOD" | "EXCELLENT" | "UNRATED"
  ad_strength    String?
  /// Final URL principal do asset group
  primary_status String?

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account  TrafficAccount  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  campaign TrafficCampaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  group_assets TrafficAssetGroupAsset[]

  @@unique([account_id, google_asset_group_id])
  @@index([tenant_id, status])
  @@index([campaign_id])
}

/// Cache de asset_group_asset (link N:N entre AssetGroup × Asset). Cada
/// link tem um field_type (qual papel o asset cumpre no group) e um
/// performance_label avaliado pelo Google.
model TrafficAssetGroupAsset {
  id             String @id @default(uuid())
  tenant_id      String
  account_id     String
  asset_group_id String

  /// Resource name do asset 'customers/X/assets/Y'
  asset_resource_name String
  /// asset.id do Google
  google_asset_id     String
  /// Tipo do asset: TEXT | IMAGE | YOUTUBE_VIDEO | CALL_TO_ACTION | etc
  asset_type          String?
  /// Conteudo do asset (text quando TEXT, url quando IMAGE/VIDEO etc)
  asset_text          String? @db.Text
  /// URL absoluta do recurso (image_url, video_url)
  asset_url           String?

  /// Field type: HEADLINE | LONG_HEADLINE | DESCRIPTION | MARKETING_IMAGE
  /// SQUARE_MARKETING_IMAGE | LOGO | YOUTUBE_VIDEO | CALL_TO_ACTION_SELECTION
  /// BUSINESS_NAME | etc
  field_type String

  /// Avaliacao do Google: LOW | GOOD | BEST | LEARNING | PENDING | UNSPECIFIED
  performance_label String?

  /// Status do link: ENABLED | PAUSED | REMOVED
  status String?

  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account     TrafficAccount    @relation(fields: [account_id], references: [id], onDelete: Cascade)
  asset_group TrafficAssetGroup @relation(fields: [asset_group_id], references: [id], onDelete: Cascade)

  @@unique([asset_group_id, google_asset_id, field_type])
  @@index([account_id, performance_label])
  @@index([asset_type])
}

// ─────────────────────────────────────────────────────────────────────────
// REACH PLANNING (Sprint F)
//
// Forecasts gerados pelo admin via UI (planejamento de campanha branding
// pre-execucao). Cache permite reabrir o forecast sem re-rodar a API.
// ─────────────────────────────────────────────────────────────────────────

model TrafficReachForecast {
  id         String @id @default(uuid())
  tenant_id  String
  account_id String

  /// Nome dado pelo admin ao forecast
  name String

  /// Snapshot dos parametros enviados (location_ids, age_ranges, devices,
  /// products, budgets, duration). Util pra reproduzir o calculo.
  request_params Json

  /// Resposta crua da API (curves + base_metrics). Pode ser grande.
  response_payload Json

  /// Resumo extraido pra exibir na UI sem parsear JSON inteiro:
  ///   total_reach, on_target_reach, total_impressions, total_views,
  ///   total_cost_micros, cpm_micros, on_target_cpm_micros
  summary Json

  /// Status do request: "PENDING" | "READY" | "ERROR"
  status        String  @default("PENDING")
  error_message String? @db.Text

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account TrafficAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([account_id, status])
}
