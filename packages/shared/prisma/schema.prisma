generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                         String                           @id @default(uuid())
  name                       String
  conversations              Conversation[]
  leads                      Lead[]
  tasks                      Task[]
  users                      User[]
  inboxes                    Inbox[]
  instances                  Instance[]
  legal_cases                LegalCase[]
  calendar_events            CalendarEvent[]
  appointment_types          AppointmentType[]
  holidays                   Holiday[]
  case_documents             CaseDocument[]
  task_attachments           TaskAttachment[]
  case_transcriptions        CaseTranscription[]
  case_deadlines             CaseDeadline[]
  petitions                  CasePetition[]
  legal_templates            LegalTemplate[]
  case_honorarios            CaseHonorario[]
  ai_chats                   AiChat[]
  followup_sequences         FollowupSequence[]
  financial_transactions     FinancialTransaction[]
  financial_categories       FinancialCategory[]
  payment_gateway_customers  PaymentGatewayCustomer[]
  payment_gateway_charges    PaymentGatewayCharge[]
  notas_fiscais              NotaFiscal[]
  tax_records                TaxRecord[]
  broadcast_jobs             BroadcastJob[]
  djen_ignored_processes     DjenIgnoredProcess[]
  lead_honorarios            LeadHonorario[]
  notifications              Notification[]
  memories                   Memory[]
  lead_profiles              LeadProfile[]
  organization_profile       OrganizationProfile?
  monthly_goals              MonthlyGoal[]
  financial_attachments      FinancialTransactionAttachment[]
  reports                    Report[]
  traffic_accounts           TrafficAccount[]
  traffic_campaigns          TrafficCampaign[]
  traffic_metrics_daily      TrafficMetricDaily[]
  traffic_alerts             TrafficAlert[]
  traffic_settings           TrafficSettings?
  traffic_sync_logs          TrafficSyncLog[]
  traffic_mutate_logs        TrafficMutateLog[]
  traffic_ad_groups          TrafficAdGroup[]
  traffic_keywords           TrafficKeyword[]
  traffic_ads                TrafficAd[]
  traffic_budgets            TrafficCampaignBudget[]
  traffic_bulk_jobs          TrafficBulkJob[]
  traffic_conversion_actions TrafficConversionAction[]
  traffic_oci_uploads        TrafficOCIUpload[]
  traffic_lead_form_subs     TrafficLeadFormSubmission[]
  traffic_ia_decisions       TrafficIADecision[]
  traffic_ia_memory          TrafficIAMemory[]
  traffic_ia_policy          TrafficIAPolicy?
  traffic_user_lists         TrafficUserList[]
  traffic_user_list_members  TrafficUserListMember[]
  traffic_recommendations    TrafficRecommendation[]
  traffic_asset_groups       TrafficAssetGroup[]
  traffic_asset_group_assets TrafficAssetGroupAsset[]
  traffic_reach_forecasts    TrafficReachForecast[]
}

model User {
  id                             String                           @id @default(uuid())
  tenant_id                      String?
  name                           String
  email                          String                           @unique
  phone                          String?
  password_hash                  String
  roles                          String[]                         @default(["OPERADOR"])
  specialties                    String[]                         @default([])
  oab_number                     String? // Número OAB (ex: "14209")
  oab_uf                         String? // UF da OAB (ex: "AL")
  // Provider de transcrição preferido: 'whisper-local' | 'groq' | NULL (usa default global TRANSCRIPTION_PROVIDER)
  // Configurado pelo admin em Configurações > Transcrição.
  transcription_provider         String?
  created_at                     DateTime                         @default(now())
  updated_at                     DateTime                         @updatedAt
  audit_logs                     AuditLog[]
  assigned_convos                Conversation[]                   @relation("AssignedUser")
  lawyer_convos                  Conversation[]                   @relation("AssignedLawyer")
  lead_notes                     LeadNote[]
  stage_history_actor            LeadStageHistory[]               @relation("StageHistoryActor")
  inboxes                        Inbox[]
  sectors                        Sector[]                         @relation("SectorUsers")
  tasks                          Task[]
  tenant                         Tenant?                          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lawyer_cases                   LegalCase[]                      @relation("LawyerCases")
  task_comments                  TaskComment[]
  supervisors                    User[]                           @relation("InternSupervisors")
  interns                        User[]                           @relation("InternSupervisors")
  calendar_events_assigned       CalendarEvent[]                  @relation("EventAssigned")
  calendar_events_created        CalendarEvent[]                  @relation("EventCreator")
  calendar_events_completed      CalendarEvent[]                  @relation("EventCompleter")
  tasks_completed                Task[]                           @relation("TaskCompleter")
  deadlines_completed            CaseDeadline[]                   @relation("DeadlineCompleter")
  schedules                      UserSchedule[]
  calendar_event_comments        CalendarEventComment[]
  transfer_audios                TransferAudio[]                  @relation("AudioUploader")
  uploaded_documents             CaseDocument[]                   @relation("DocumentUploader")
  uploaded_task_attachments      TaskAttachment[]                 @relation("TaskAttachmentUploader")
  uploaded_transcriptions        CaseTranscription[]              @relation("TranscriptionUploader")
  created_deadlines              CaseDeadline[]                   @relation("DeadlineCreator")
  authored_petitions             CasePetition[]                   @relation("PetitionAuthor")
  reviewed_petitions             CasePetition[]                   @relation("PetitionReviewer")
  saved_versions                 PetitionVersion[]                @relation("VersionSaver")
  created_templates              LegalTemplate[]                  @relation("TemplateCreator")
  ai_chats                       AiChat[]                         @relation("AiChatOwner")
  cs_leads                       Lead[]                           @relation("CSManager")
  financial_transactions         FinancialTransaction[]           @relation("FinancialLawyer")
  monthly_goals_as_lawyer        MonthlyGoal[]                    @relation("MonthlyGoalLawyer")
  monthly_goals_created          MonthlyGoal[]                    @relation("MonthlyGoalCreator")
  financial_attachments_uploaded FinancialTransactionAttachment[] @relation("FinancialAttachmentUploader")
  reports_generated              Report[]                         @relation("ReportGeneratedBy")
  tax_records                    TaxRecord[]                      @relation("TaxRecordLawyer")
  conversation_notes             ConversationNote[]               @relation("ConversationNoteAuthor")
  broadcast_jobs                 BroadcastJob[]
  notification_setting           NotificationSetting?
  conversation_mutes             ConversationMute[]
  notifications                  Notification[]
  push_subscriptions             PushSubscription[]
}

model Lead {
  id                  String   @id @default(uuid())
  tenant_id           String?
  name                String?
  // Unicidade ISOLADA por tenant — vide @@unique([tenant_id, phone]).
  // Antes era @unique global, mas isso impedia dois tenants distintos de
  // terem o mesmo telefone como lead, causando vazamento entre tenants
  // (notificacao do tenant A indo pra cliente cadastrado no tenant B).
  // Bug reportado em 2026-04-29.
  phone               String
  email               String?
  origin              String?
  stage               String   @default("QUALIFICANDO")
  stage_entered_at    DateTime @default(now())
  loss_reason         String?
  profile_picture_url String?
  tags                String[]
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // ─── Separação Lead vs Cliente ────────────────────────────
  // Quando true: lead se tornou cliente (contrato assinado/FINALIZADO)
  is_client        Boolean   @default(false)
  became_client_at DateTime?
  // Operador que fechou a venda — mantém vínculo pós-conversão
  cs_user_id       String?
  cs_user          User?     @relation("CSManager", fields: [cs_user_id], references: [id], onDelete: SetNull)

  // Opt-out de lembretes de cobrança via WhatsApp. Cliente pode pedir
  // pra parar de receber mensagens de honorarios sem afetar outras
  // notificacoes (movimentacoes, agendamento).
  payment_reminders_disabled Boolean @default(false)

  // Google Drive
  google_drive_folder_id String?

  // ─── Atribuicao Google Ads (capturada no clique/form) ─────────
  /// Click ID padrao Google Ads (web/Search). Valido por 90 dias.
  google_gclid    String?
  /// Click ID YouTube (iOS sem cookie)
  google_gbraid   String?
  /// Click ID Web (iOS sem cookie)
  google_wbraid   String?
  /// Quando o clique aconteceu (= criacao do lead se gclid presente)
  google_click_at DateTime?
  // UTM tags
  utm_source      String?
  utm_medium      String?
  utm_campaign    String?
  utm_content     String?
  utm_term        String?

  profile                   LeadProfile?
  conversations             Conversation[]
  tenant                    Tenant?                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tasks                     Task[]
  legal_cases               LegalCase[]
  ficha_trabalhista         FichaTrabalhista?
  calendar_events           CalendarEvent[]
  last_followup_at          DateTime?
  notes                     LeadNote[]
  stage_history             LeadStageHistory[]
  contract_signatures       ContractSignature[]
  followup_enrollments      FollowupEnrollment[]
  financial_transactions    FinancialTransaction[]
  payment_gateway_customers PaymentGatewayCustomer[]
  notas_fiscais             NotaFiscal[]
  broadcast_items           BroadcastItem[]
  lead_honorarios           LeadHonorario[]
  client_login_codes        ClientLoginCode[]
  oci_uploads               TrafficOCIUpload[]
  lead_form_submissions     TrafficLeadFormSubmission[]
  cpf_cnpj                  String? // CPF ou CNPJ — facilita match com Asaas

  @@unique([tenant_id, phone])
  @@index([phone])
  @@index([stage])
  @@index([cpf_cnpj])
  @@index([is_client])
  @@index([google_gclid])
  @@index([google_gbraid])
  @@index([google_wbraid])
}

/**
 * Codigo OTP de login do cliente no portal (passwordless via WhatsApp).
 * Fluxo:
 * 1. Cliente digita telefone no /portal/login
 * 2. Backend cria ClientLoginCode com sha256(codigo) e TTL 10min
 * 3. WhatsApp do cliente recebe "Seu codigo: 1234"
 * 4. Cliente digita 4 digitos, backend valida e emite JWT (audience=client)
 * code_hash: NUNCA armazenar plaintext. sha256(code) — sufientemente seguro
 * pra OTP curto + TTL 10min + max 5 attempts.
 */
model ClientLoginCode {
  id         String    @id @default(uuid())
  lead_id    String
  code_hash  String // sha256 do codigo de 4 digitos
  expires_at DateTime // now + 10min
  attempts   Int       @default(0)
  used_at    DateTime?
  ip_address String?
  created_at DateTime  @default(now())

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id, expires_at])
  @@index([lead_id, used_at])
}

model Conversation {
  id                         String              @id @default(uuid())
  tenant_id                  String?
  lead_id                    String
  channel                    String              @default("whatsapp")
  external_id                String?
  status                     String              @default("ABERTO")
  ai_mode                    Boolean             @default(true)
  ai_mode_disabled_at        DateTime? // Timestamp de quando ai_mode foi desligado (para auto-reativação)
  ai_mode_source             String? // "MANUAL" | "CRON_AFTER_HOURS" | null — origem da última mudança em ai_mode
  assigned_user_id           String?
  inbox_id                   String?
  instance_name              String? // Nome da instancia de origem (ex: wa1)
  pending_transfer_to_id     String?
  pending_transfer_from_id   String?
  pending_transfer_reason    String?
  pending_transfer_audio_ids String[]            @default([])
  legal_area                 String? // Area do direito detectada pela IA
  assigned_lawyer_id         String? // Advogado pre-designado pela IA
  origin_assigned_user_id    String? // Quem transferiu (para devolucao)
  linked_agent_ids           String[]            @default([]) // Todos os agentes que atenderam
  next_step                  String? // Proximo passo: "duvidas" | "triagem_concluida" | "formulario" | "reuniao" | "encerrado"
  ai_notes                   String? // Observacoes internas da IA (campo notes do JSON)
  reminder_context           Json? // Contexto do ultimo lembrete WhatsApp enviado ao cliente (audiencia/prazo)
  last_message_at            DateTime            @default(now())
  assigned_user              User?               @relation("AssignedUser", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  assigned_lawyer            User?               @relation("AssignedLawyer", fields: [assigned_lawyer_id], references: [id], onDelete: SetNull)
  lead                       Lead                @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant                     Tenant?             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inbox                      Inbox?              @relation(fields: [inbox_id], references: [id], onDelete: SetNull)
  messages                   Message[]
  tasks                      Task[]
  legal_cases                LegalCase[]
  calendar_events            CalendarEvent[]
  transfer_audios            TransferAudio[]
  contract_signatures        ContractSignature[]
  notes                      ConversationNote[]
  mutes                      ConversationMute[]

  @@index([lead_id])
  @@index([last_message_at(sort: Desc)])
  @@index([instance_name])
  @@index([tenant_id])
  @@index([assigned_user_id])
  @@index([status])
  @@index([pending_transfer_to_id])
  @@index([inbox_id])
}

model Message {
  id                  String            @id @default(uuid())
  conversation_id     String
  direction           String
  type                String
  text                String?
  external_message_id String?           @unique
  status              String
  created_at          DateTime          @default(now())
  reply_to_id         String?
  reply_to_text       String?
  skill_id            String? // Qual PromptSkill gerou esta resposta IA
  media               Media?
  reactions           MessageReaction[]
  conversation        Conversation      @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  reply_to            Message?          @relation("MessageReplies", fields: [reply_to_id], references: [id], onDelete: SetNull)
  replies             Message[]         @relation("MessageReplies")
  skill               PromptSkill?      @relation(fields: [skill_id], references: [id], onDelete: SetNull)
  tasks               Task[]

  @@index([conversation_id, created_at])
  @@index([external_message_id])
}

model MessageReaction {
  id          String   @id @default(uuid())
  message_id  String
  user_id     String?
  contact_jid String?
  emoji       String
  created_at  DateTime @default(now())
  message     Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@unique([message_id, user_id])
  @@unique([message_id, contact_jid])
  @@index([message_id])
}

model Media {
  id            String   @id @default(uuid())
  message_id    String   @unique
  s3_key        String? /// DEPRECATED: path no MinIO (mídias antigas). Novo: usar file_path.
  file_path     String? /// Path relativo a MEDIA_STORAGE_PATH (ex: "2026/04/uuid.ogg")
  mime_type     String
  size          Int?
  duration      Int?
  checksum      String?
  original_url  String? /// URL temporária Evolution CDN (fallback, expira ~48h)
  original_name String?
  created_at    DateTime @default(now())
  message       Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model Task {
  id                String              @id @default(uuid())
  tenant_id         String?
  lead_id           String?
  conversation_id   String?
  message_id        String?
  legal_case_id     String?
  calendar_event_id String?             @unique
  title             String
  description       String?
  due_at            DateTime?
  status            String              @default("A_FAZER")
  assigned_user_id  String?
  created_at        DateTime            @default(now())
  // Tracking de progresso pro advogado acompanhar sem ter que perguntar:
  //   viewed_at  : 1a vez que o responsavel viu o card no dashboard
  //   started_at : quando clicou "Iniciar" (virou EM_PROGRESSO)
  viewed_at         DateTime?
  started_at        DateTime?
  // Conclusão
  completion_note   String?
  completed_at      DateTime?
  completed_by_id   String?
  // Adiamentos
  postpone_count    Int                 @default(0)
  created_by_id     String?
  assigned_user     User?               @relation(fields: [assigned_user_id], references: [id], onDelete: SetNull)
  completed_by      User?               @relation("TaskCompleter", fields: [completed_by_id], references: [id], onDelete: SetNull)
  conversation      Conversation?       @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  lead              Lead?               @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  message           Message?            @relation(fields: [message_id], references: [id], onDelete: SetNull)
  tenant            Tenant?             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  legal_case        LegalCase?          @relation(fields: [legal_case_id], references: [id], onDelete: SetNull)
  calendar_event    CalendarEvent?      @relation(fields: [calendar_event_id], references: [id], onDelete: SetNull)
  comments          TaskComment[]
  checklist_items   TaskChecklistItem[]
  postponements     TaskPostponement[]
  attachments       TaskAttachment[]

  @@index([assigned_user_id, due_at])
  @@index([status])
  @@index([legal_case_id])
  @@index([tenant_id])
  @@index([lead_id])
  // Pra queries do advogado tipo "minhas diligencias que ainda nao
  // foram vistas pelo estagiario" — cobranca proativa
  @@index([created_by_id, viewed_at])
}

// Anexos de Task (diligencias). Uploadados pelo estagiario na hora de
// concluir a diligencia (ex: comprovante de residencia que o cliente
// mandou via WhatsApp). Quando a Task tem legal_case_id, esses anexos
// aparecem TAMBEM na aba Documentos do workspace do processo via UNION
// na query — sem duplicar registros (TaskAttachment eh fonte unica).
//
// Quando a Task NAO tem legal_case_id, anexo fica visivel so na propria
// diligencia (cobertura pra casos tipo "ir ao cartorio comprar selo"
// que nao tem processo associado mas tem comprovante).
model TaskAttachment {
  id             String   @id @default(uuid())
  tenant_id      String?
  task_id        String
  uploaded_by_id String
  name           String // Nome amigavel — pode ser editado pelo usuario
  original_name  String // Nome original do arquivo no upload
  s3_key         String // Chave no MinIO/S3 (mesmo bucket de CaseDocument)
  mime_type      String
  size           Int // bytes
  // Pasta sugerida (CLIENTE/CONTRATOS/etc) — usada quando o documento eh
  // espelhado no workspace do processo. Sem efeito quando Task nao tem
  // legal_case_id.
  folder         String   @default("OUTROS")
  description    String?
  created_at     DateTime @default(now())

  task        Task    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tenant      Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  uploaded_by User    @relation("TaskAttachmentUploader", fields: [uploaded_by_id], references: [id])

  @@index([task_id])
  @@index([tenant_id])
}

model TaskPostponement {
  id            String   @id @default(uuid())
  task_id       String
  task          Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  old_due_at    DateTime
  new_due_at    DateTime
  reason        String
  created_by_id String?
  created_at    DateTime @default(now())

  @@index([task_id])
}

// model AiMemory REMOVIDO em 2026-04-20 (fase 2d-3 da remocao total do sistema
// antigo de memoria). Substituido pelo sistema novo: LeadProfile (perfil em
// prosa consolidado pela IA) + Memory (entries individuais tipadas). Ver
// MEMORY_SYSTEM.md secao 9.6 (migracao case_state -> LeadProfile).
//
// Migration SQL acompanha este commit em packages/shared/prisma/migrations/.
// Dados anteriores (132 registros no banco de producao) foram migrados para
// LeadProfile antes do DROP TABLE.

model PromptSkill {
  id                 String       @id @default(uuid())
  name               String
  area               String
  system_prompt      String
  tools_policy_json  Json         @default("[]")
  version            Int          @default(1)
  active             Boolean      @default(true)
  model              String       @default("gpt-4o-mini")
  max_tokens         Int          @default(300)
  temperature        Float        @default(0.7)
  handoff_signal     String? // Palavra que a IA usa para sinalizar escalada ao humano (ex: "ESCALAR_HUMANO")
  order              Int          @default(0)
  // ─── Skills V2 ───────────────────────────────────────────────
  description        String? // Descrição curta para o router (1 linha)
  trigger_keywords   String[]     @default([]) // Hints para o router: ["agendamento", "reuniao"]
  skill_type         String       @default("specialist") // "specialist" | "utility"
  max_context_tokens Int          @default(4000) // Budget de tokens para injeção de references
  provider           String       @default("openai") // "openai" | "anthropic"
  // ─────────────────────────────────────────────────────────────
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  messages           Message[]
  tools              SkillTool[]
  assets             SkillAsset[]
}

model SkillTool {
  id              String      @id @default(uuid())
  skill_id        String
  name            String // Nome da função: "book_appointment", "save_form_field"
  description     String // Descrição para function calling
  parameters_json Json // JSON Schema dos parâmetros da função
  handler_type    String // "builtin" | "webhook"
  handler_config  Json        @default("{}") // { "builtin": "book_appointment" } ou { "url": "...", "method": "POST" }
  active          Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  skill           PromptSkill @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@unique([skill_id, name])
  @@index([skill_id])
}

model SkillAsset {
  id           String      @id @default(uuid())
  skill_id     String
  name         String // "PAPEL_TIMBRADO.docx", "expressoes-juridicas.md"
  s3_key       String // Chave no S3/MinIO
  mime_type    String
  size         Int // bytes
  asset_type   String // "asset" | "reference"
  inject_mode  String      @default("none") // "none" | "full_text" | "summary"
  content_text String? // Texto extraído (para references com inject_mode != "none")
  created_at   DateTime    @default(now())
  skill        PromptSkill @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@index([skill_id, asset_type])
}

model SkillExecutionLog {
  id               String   @id @default(uuid())
  conversation_id  String
  skill_id         String?
  tool_calls_json  Json? // Array de tool calls executados
  selection_reason String? // Motivo da seleção pelo router
  router_tokens    Int? // Tokens usados pelo router
  duration_ms      Int?
  created_at       DateTime @default(now())

  @@index([conversation_id, created_at])
  @@index([skill_id])
}

model AuditLog {
  id            String   @id @default(uuid())
  actor_user_id String?
  action        String
  entity        String
  entity_id     String
  meta_json     Json?
  created_at    DateTime @default(now())
  actor         User?    @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([actor_user_id, created_at])
  @@index([entity, entity_id])
}

model GlobalSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
}

model AiUsage {
  id                String   @id @default(uuid())
  conversation_id   String?
  skill_id          String?
  model             String
  call_type         String // 'chat' | 'memory' | 'whisper'
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  cost_usd          Float    @default(0)
  created_at        DateTime @default(now())

  @@index([created_at])
  @@index([model])
  @@index([conversation_id])
}

model Inbox {
  id            String         @id @default(uuid())
  tenant_id     String?
  name          String
  rr_pointer    String? // ID do ultimo usuario atribuido (round-robin)
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  tenant        Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users         User[]
  conversations Conversation[]
  instances     Instance[]

  @@index([tenant_id])
}

model Instance {
  id         String   @id @default(uuid())
  tenant_id  String?
  inbox_id   String?
  name       String   @unique
  type       String   @default("whatsapp")
  connection String   @default("evolution")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenant     Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inbox      Inbox?   @relation(fields: [inbox_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([inbox_id])
}

model TransferAudio {
  id              String   @id @default(uuid())
  conversation_id String
  s3_key          String
  mime_type       String   @default("audio/webm")
  size            Int?
  uploaded_by_id  String?
  expires_at      DateTime // 7 dias apos upload — apagado pelo cron
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  uploaded_by  User?        @relation("AudioUploader", fields: [uploaded_by_id], references: [id], onDelete: SetNull)

  @@index([conversation_id])
  @@index([expires_at])
}

model LpEvent {
  id           String   @id @default(uuid())
  page_path    String // "/", "/geral/arapiraca", "/lp/teste"
  event_type   String // "view" | "whatsapp_click"
  visitor_id   String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  utm_term     String?
  utm_content  String?
  gclid        String?
  referrer     String?
  created_at   DateTime @default(now())

  @@index([page_path, created_at])
  @@index([event_type])
}

model Sector {
  id         String   @id @default(uuid())
  name       String
  auto_route Boolean  @default(false)
  created_at DateTime @default(now())
  users      User[]   @relation("SectorUsers")
}

model LegalCase {
  id                     String    @id @default(uuid())
  tenant_id              String?
  lead_id                String
  conversation_id        String?
  lawyer_id              String
  case_number            String?
  legal_area             String?
  stage                  String    @default("VIABILIDADE")
  in_tracking            Boolean   @default(false) // true = passou para menu Processos
  tracking_stage         String? // stage dentro do menu Processos
  filed_at               DateTime? // quando foi protocolado/ajuizado
  archived               Boolean   @default(false)
  archive_reason         String?
  renounced              Boolean   @default(false) // renúncia: advogado não atua mais no processo
  renounced_at           DateTime?
  notes                  String?
  court                  String?
  action_type            String? // Tipo de ação (Reclamatória Trabalhista, Indenizatória, etc.)
  claim_value            Decimal? // Valor da causa
  sentence_value         Decimal? // Valor da condenação (preenchido na EXECUCAO)
  sentence_date          DateTime? // Data da sentença/acórdão
  sentence_type          String? // PROCEDENTE, PARCIAL, IMPROCEDENTE, ACORDO
  opposing_party         String? // Parte contrária (nome)
  // Polo processual do cliente. true = cliente eh autor (polo ativo),
  // false = cliente eh reu (polo passivo). Default true porque a maior parte
  // dos processos do escritorio eh com o cliente autorando a acao.
  // A IA usa esse campo pra se referir corretamente ao processo ("seu processo
  // contra X" vs "processo de X contra voce"). Adicionado 2026-04-24.
  client_is_author       Boolean   @default(true)
  judge                  String? // Juiz/Desembargador
  priority               String    @default("NORMAL") // URGENTE | NORMAL | BAIXA
  google_drive_folder_id String? // Pasta do caso no Google Drive
  stage_changed_at       DateTime  @default(now()) // quando mudou de etapa
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  lead                   Lead                   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  conversation           Conversation?          @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  lawyer                 User                   @relation("LawyerCases", fields: [lawyer_id], references: [id])
  tenant                 Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tasks                  Task[]
  events                 CaseEvent[]
  djen_publications      DjenPublication[]
  calendar_events        CalendarEvent[]
  documents              CaseDocument[]
  deadlines              CaseDeadline[]
  petitions              CasePetition[]
  transcriptions         CaseTranscription[]
  honorarios             CaseHonorario[]
  financial_transactions FinancialTransaction[]
  gateway_charges        PaymentGatewayCharge[]

  @@index([lawyer_id, stage])
  @@index([lead_id])
  @@index([stage])
  @@index([in_tracking])
  @@index([tenant_id])
}

model CaseEvent {
  id            String    @id @default(uuid())
  case_id       String
  type          String // MOVIMENTACAO, PUBLICACAO, MANUAL, etc.
  title         String
  description   String?
  source        String? // ESAJ, DJEN, MANUAL
  reference_url String?
  event_date    DateTime?
  created_at    DateTime  @default(now())

  // Campos para sync ESAJ — dedup e notificação
  movement_hash      String?   @unique // SHA256(case_number|date|description)
  notified_at        DateTime? // quando WhatsApp foi enviado ao advogado
  client_notified_at DateTime? // quando WhatsApp foi enviado ao cliente
  client_explanation String? // explicação leiga gerada pela IA on-demand (cache)
  source_raw         Json? // dado bruto da movimentação

  legal_case LegalCase @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, created_at])
  @@index([source, notified_at])
  @@index([source, client_notified_at])
}

model TaskComment {
  id         String   @id @default(uuid())
  task_id    String
  user_id    String
  text       String
  created_at DateTime @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

