MCP_PORT=3100
MCP_AUTH_TOKEN=troque-este-token
MCP_PUBLIC_BASE_URL=https://andrelustosaadvogados.com.br/traffic-mcp
MCP_PUBLIC_URL=https://andrelustosaadvogados.com.br/traffic-mcp/mcp

# Opcional. Se vazio, o formulario OAuth aceita o proprio MCP_AUTH_TOKEN.
MCP_OAUTH_AUTHORIZATION_TOKEN=
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
MCP_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# Modo recomendado: o MCP chama a API do CRM, e o CRM continua cuidando
# das credenciais Google Ads criptografadas.
TRAFFIC_MCP_MODE=crm
CRM_API_URL=https://andrelustosaadvogados.com.br/api
CRM_API_KEY=

# Modo alternativo: acesso direto ao Google Ads.
# Use somente se quiser duplicar as credenciais fora do CRM.
# TRAFFIC_MCP_MODE=google_ads
#
# Pode usar estes nomes do MCP:
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Ou reutilizar os nomes que o CRM ja usa:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=446-412-9633
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

CACHE_TTL_MS=300000
REPORT_DAILY_LIMIT=9500
WRITE_AUDIT_LOG=./logs/write-audit.log
